# Breaking change detected — still plan but Generator checks --breaking flag
# Architecture doc: Clef Bind, Sync Section 3.2

sync BlockOnBreaking [eager]
when {
  Projection/validate: [ projection: ?p ]
    => [ projection: ?p; changes: ?changes ]
}
then {
  Generator/plan: [ suite: ?suite; interfaceManifest: ?manifest ]
}
