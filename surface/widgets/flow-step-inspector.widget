@version(1)
widget flow-step-inspector {

  purpose {
    Tab strip container for the Flow Builder step inspector. Hosts contextual
    configuration panels for a selected process step. Three tabs are always
    visible — Action, I/O Mapping, and Error — enforcing that the core
    concerns of every step are always reachable. Four conditional tabs
    appear based on step capability: Retry when the step kind supports
    retry, Compensation when the step has a compensable side effect, LLM
    when the step kind is llm-call, and Connector when the step kind is
    connector-call. LLM and Connector are mutually exclusive — a step
    cannot be both. Keyboard shortcuts Ctrl+1 through Ctrl+7 jump to
    visible tabs by ordinal position, preserving the progressive-disclosure
    principle: non-applicable tabs are hidden rather than disabled so
    they never create dead-end navigation targets.
  }

  anatomy {
    root:        container    { Top-level wrapper enclosing the tab strip and the active panel }
    tabList:     container    { Horizontal row of tab buttons }
    tab:         action       { Individual tab button; one per visible tab }
    tabPanel:    container    { Content region hosting all panel slots; only the active panel is shown }
    activePanel: container    { Inner content wrapper for the currently selected tab panel }
  }

  slots {
    action-editor          { Content for the Action tab }
    data-mapping           { Content for the I/O Mapping tab }
    error-branch           { Content for the Error tab }
    retry-policy-editor    { Content for the Retry tab; rendered only when tab is visible }
    compensation-plan-editor { Content for the Compensation tab; rendered only when tab is visible }
    llm-step-config        { Content for the LLM tab; rendered only when step.kind is llm-call }
    connector-step-config  { Content for the Connector tab; rendered only when step.kind is connector-call }
  }

  states {
    tab-active [initial] {
      on SELECT_TAB    -> tab-active;
      on JUMP_TAB_1    -> tab-active;
      on JUMP_TAB_2    -> tab-active;
      on JUMP_TAB_3    -> tab-active;
      on JUMP_TAB_4    -> tab-active;
      on JUMP_TAB_5    -> tab-active;
      on JUMP_TAB_6    -> tab-active;
      on JUMP_TAB_7    -> tab-active;
      on FOCUS_NEXT    -> tab-active;
      on FOCUS_PREV    -> tab-active;
      entry [activateTab];
    }
  }

  accessibility {
    role: tablist;
    keyboard {
      ArrowLeft    -> FOCUS_PREV;
      ArrowRight   -> FOCUS_NEXT;
      Home         -> JUMP_TAB_1;
      End          -> JUMP_TAB_7;
      Enter        -> SELECT_TAB;
      Space        -> SELECT_TAB;
      Ctrl+1       -> JUMP_TAB_1;
      Ctrl+2       -> JUMP_TAB_2;
      Ctrl+3       -> JUMP_TAB_3;
      Ctrl+4       -> JUMP_TAB_4;
      Ctrl+5       -> JUMP_TAB_5;
      Ctrl+6       -> JUMP_TAB_6;
      Ctrl+7       -> JUMP_TAB_7;
    }
    focus {
      trap: false;
      initial: tab;
      roving: true;
    }
    aria {
      root -> {
        data-state: state;
        data-active-tab: ?activeTab;
        data-step-kind: ?stepKind;
      };
      tabList -> {
        role: "tablist";
        aria-label: "Step inspector tabs";
        aria-orientation: "horizontal";
      };
      tab -> {
        role: "tab";
        aria-selected: if self.id == ?activeTab then "true" else "false";
        aria-controls: concat("panel-", self.id);
        tabindex: if self.id == ?activeTab then "0" else "-1";
      };
      tabPanel -> {
        role: "tabpanel";
        aria-labelledby: concat("tab-", ?activeTab);
      };
      activePanel -> {
        role: "presentation";
        aria-hidden: "false";
      };
    }
  }

  props {
    stepId:      String = ""
    stepKind:    String = ""
    activeTab:   String = "action"
    visibleTabs: list String = ["action", "data-mapping", "error"]
  }

  connect {
    root -> {
      data-part: "root";
      data-state: state;
      data-active-tab: ?activeTab;
      data-step-kind: ?stepKind;
    }

    tabList -> {
      data-part: "tab-list";
    }

    tab -> {
      data-part: "tab";
      data-tab-id: self.id;
      data-selected: if self.id == ?activeTab then "true" else "false";
      data-visible: if self.id in ?visibleTabs then "true" else "false";
      hidden: if not self.id in ?visibleTabs then true else false;
      tabindex: if self.id == ?activeTab then "0" else "-1";
      onClick: send(SELECT_TAB, { tabId: self.id });
      onKeyDown: if key == "ArrowLeft" then send(FOCUS_PREV) else if key == "ArrowRight" then send(FOCUS_NEXT) else if key == "Home" then send(JUMP_TAB_1) else if key == "End" then send(JUMP_TAB_7) else if key == "Enter" or key == "Space" then send(SELECT_TAB, { tabId: self.id }) else noop;
    }

    tabPanel -> {
      data-part: "tab-panel";
      data-tab-id: ?activeTab;
    }

    activePanel -> {
      data-part: "active-panel";
      data-tab-id: ?activeTab;
    }
  }

  compose {
    _actionEditor:            widget("action-editor",            {})
    _dataMapping:             widget("data-mapping",             {})
    _errorBranch:             widget("error-branch",             {})
    _retryPolicyEditor:       widget("retry-policy-editor",      {})
    _compensationPlanEditor:  widget("compensation-plan-editor", {})
    _llmStepConfig:           widget("llm-step-config",          {})
    _connectorStepConfig:     widget("connector-step-config",    {})
  }

  invariant {
    example "action tab active by default": {
      after root -> { data-active-tab: "action" }
      then tab.action -> { data-selected: "true" }
      and tab.data-mapping -> { data-selected: "false" }
      and tab.error -> { data-selected: "false" }
    }

    example "select data-mapping tab": {
      after tab.click({ tabId: "data-mapping" }) -> ok
      then root -> { data-active-tab: "data-mapping" }
      and tab.data-mapping -> { data-selected: "true" }
      and tab.action -> { data-selected: "false" }
    }

    example "retry tab hidden when not in visibleTabs": {
      after root -> { data-step-kind: "http-call" }
      then tab.retry -> { data-visible: "false" }
      and tab.retry -> { hidden: true }
    }

    example "retry tab visible when in visibleTabs": {
      after root -> { data-step-kind: "http-call" }
      and root -> { data-visible-tabs: "action,retry,data-mapping,error" }
      then tab.retry -> { data-visible: "true" }
      and tab.retry -> { hidden: false }
    }

    example "llm tab visible when stepKind is llm-call": {
      after root -> { data-step-kind: "llm-call" }
      and root -> { data-visible-tabs: "action,data-mapping,error,llm" }
      then tab.llm -> { data-visible: "true" }
      and tab.connector -> { data-visible: "false" }
    }

    example "connector tab visible when stepKind is connector-call": {
      after root -> { data-step-kind: "connector-call" }
      and root -> { data-visible-tabs: "action,data-mapping,error,connector" }
      then tab.connector -> { data-visible: "true" }
      and tab.llm -> { data-visible: "false" }
    }

    example "Ctrl+1 jumps to first visible tab": {
      after tab.click({ tabId: "data-mapping" }) -> ok
      then send(JUMP_TAB_1) -> ok
      then tab.action -> { data-selected: "true" }
    }

    example "Ctrl+3 jumps to third visible tab": {
      after send(JUMP_TAB_3) -> ok
      then root -> { data-active-tab: "error" }
    }

    always "data-state on root reflects FSM": {
      root -> { data-state: state }
    }

    always "exactly one tab is selected": {
      forall t in tab:
        t -> { data-selected: if t.id == ?activeTab then "true" else "false" }
    }

    always "action tab always visible": {
      tab.action -> { data-visible: "true" }
      and tab.action -> { hidden: false }
    }

    always "data-mapping tab always visible": {
      tab.data-mapping -> { data-visible: "true" }
      and tab.data-mapping -> { hidden: false }
    }

    always "error tab always visible": {
      tab.error -> { data-visible: "true" }
      and tab.error -> { hidden: false }
    }

    always "tabindex roving: selected tab has tabindex 0": {
      forall t in tab:
        t -> { tabindex: if t.id == ?activeTab then "0" else "-1" }
    }

    always "data-step-kind on root matches stepKind prop": {
      root -> { data-step-kind: ?stepKind }
    }

    never "LLM and Connector tabs both visible simultaneously": {
      tab.llm -> { data-visible: "true" } and tab.connector -> { data-visible: "true" }
    }

    never "non-visible tab is selected": {
      exists t in tab:
        t -> { data-visible: "false" } and t -> { data-selected: "true" }
    }

    never "two tabs simultaneously selected": {
      exists t1 in tab:
        exists t2 in tab:
          t1 != t2 and t1 -> { data-selected: "true" } and t2 -> { data-selected: "true" }
    }

    forall s in states:
      s.reachable = true

    action tab.click {
      requires: self.id in ?visibleTabs
      ensures ok: ?activeTab == self.id
      ensures ok: root -> { data-active-tab: self.id }
    }

    "SELECT_TAB updates activeTab to the tabId payload and re-renders activePanel with the matching slot content";
    "JUMP_TAB_N (1-7) selects the Nth tab in the ordered visibleTabs list; no-op if N exceeds list length";
    "visibleTabs is always a superset of action, data-mapping, and error; callers may not remove those three";
    "Ctrl+number shortcuts only fire when focus is inside the tab strip or an active panel";
    "Progressive disclosure: tabs absent from visibleTabs are not rendered in the DOM — they are hidden, not disabled";
    "stepKind prop drives conditional tab visibility at the caller level; the widget itself does not derive visibility from stepKind directly";
  }

}
