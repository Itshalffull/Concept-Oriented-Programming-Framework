derived LLMPlatform [M] {

  purpose {
    Complete LLM platform — provider abstraction and model routing (LLMCore),
    multi-turn conversation management (Conversation), prompt composition with
    token budgeting (PromptAssembly), safety guardrails and tracing (Guardrail,
    LLMTrace), RAG pipeline (VectorIndex, Retriever, DocumentChunk), agent
    execution with strategy providers (AgentLoop, AgentSession, AgentTrigger),
    agent memory and collaboration (AgentMemory, AgentTeam, AgentRole,
    AgentHandoff), alignment (Constitution), and content-native agent personas
    via ContentCompiler.
  }

  composes {
    LLMProvider [M]
    ModelRouter [M]
    Conversation [M]
    PromptAssembly [M]
    FewShotExample [M]
    PromptOptimizer [M]
    Guardrail [M]
    LLMTrace [M]
    SemanticRouter [M]
    Constitution [M]
    VectorIndex [M]
    Retriever [M]
    DocumentChunk [M]
    AgentLoop [M]
    AgentSession [M]
    AgentTrigger [M]
    AgentMemory [M]
    AgentRole [M]
    AgentTeam [M]
    AgentHandoff [M]
    ToolBinding [M]
    Blackboard [M]
    Consensus [M]
    StateGraph [M]
  }

  syncs {
    required: [
      agent-invokes-tool,
      agent-remembers-step,
      tool-result-feeds-agent,
      agent-loop-dispatches-to-strategy,
      persona-page-applies-schema,
      content-compiler-dispatches,
      session-spawns-from-persona,
      trigger-fires-session
    ]
    recommended: [
      constitution-critiques-output,
      team-delegates-via-role,
      persona-entity-reflection
    ]
  }

  surface {
    action spawnAgent(personaPageId: String, strategy: String, tools: String,
                      context: String) {
      matches: AgentSession/spawn(personaPageId: personaPageId,
                                  strategy: strategy, tools: tools,
                                  context: context)
    }

    action invokeAgent(session: M, goal: String) {
      matches: AgentSession/invoke(session: session, goal: goal)
    }

    action createTrigger(personaPageId: String, triggerType: String,
                         config: String) {
      matches: AgentTrigger/create(personaPageId: personaPageId,
                                   triggerType: triggerType,
                                   triggerConfig: config,
                                   strategy: "react", tools: "[]",
                                   cooldownMs: 0)
    }

    action compilePersona(pageId: String) {
      matches: ContentCompiler/compile(pageId: pageId)
    }

    action createConversation(contextStrategy: String) {
      matches: Conversation/create(context_strategy: contextStrategy)
    }

    action assemblePrompt(strategy: String, format: String, tokenizer: String,
                          contextWindow: Int) {
      matches: PromptAssembly/create(strategy: strategy, format: format,
                                     tokenizer: tokenizer,
                                     contextWindow: contextWindow)
    }

    action critiqueAndRevise(constitution: M, response: String, prompt: String) {
      matches: Constitution/critiqueAndRevise(constitution: constitution,
                                              response: response,
                                              prompt: prompt)
    }

    query getAgentStatus(session: M) -> AgentSession/getStatus(session: session)

    query listSessions(personaPageId: String, status: String) -> AgentSession/list(personaPageId: personaPageId, status: status)

    query getTriggerHistory(trigger: M, limit: Int) -> AgentTrigger/getHistory(trigger: trigger, limit: limit)

    query searchMemory(query: String, memoryType: String) -> AgentMemory/search(query: query, memory_type: memoryType)
  }

  principle {
    after compilePersona(pageId: "persona-1")
    then spawnAgent(personaPageId: "persona-1", strategy: "react",
                    tools: "[]", context: "{}")
    then invokeAgent(session: derivedContext, goal: "Summarise the latest news")
    then getAgentStatus(session: derivedContext) returns running or completed status
  }

  principle {
    after critiqueAndRevise(constitution: derivedContext,
                            response: "Draft output text",
                            prompt: "Explain quantum entanglement")
    then output conforms to constitution principles or revised response returned
  }

  principle {
    after assemblePrompt(strategy: "rag", format: "chat", tokenizer: "cl100k",
                         contextWindow: "8192")
    then searchMemory(query: "quantum entanglement", memoryType: "episodic")
         returns relevant chunks injected into assembled prompt
    and  invokeAgent(session: derivedContext, goal: "Answer with retrieved context")
    then getAgentStatus(session: derivedContext) returns completed status
  }
}
