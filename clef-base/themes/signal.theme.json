{
  "name": "signal",
  "colorSpace": { "algorithm": "oklch", "gamut": "srgb", "seed": { "primary": "160" } },
  "colorScheme": {
    "activeMode": "dark",
    "modes": {
      "light": {
        "primary": "#0f766e",
        "onPrimary": "#f4fffd",
        "surface": "#f2fbfa",
        "background": "#e8f8f5",
        "foreground": "#082f2d"
      },
      "dark": {
        "primary": "#2dd4bf",
        "onPrimary": "#032c2a",
        "surface": "#0a1416",
        "background": "#050b0d",
        "foreground": "#dcfff8"
      }
    }
  },
  "density": { "mode": "compact", "multiplier": 0.88, "exempt": ["dialog", "datepicker"] },
  "scope": { "global": { "depth": 0 }, "content": { "depth": 1 } },
  "typeScale": { "baseSize": 15, "ratio": 1.2, "steps": { "body": "14px", "heading": "23px" } },
  "fontMetrics": { "family": "IBM Plex Sans, system-ui, sans-serif", "features": { "body": ["liga"], "data": ["tnum"] } },
  "shape": { "family": "rounded", "radius": "0.375rem" },
  "iconography": { "variant": "outlined", "gradeCompensation": -25 },
  "material": {
    "kind": "glass",
    "shadows": {
      "1": "0 1px 2px rgba(3, 10, 12, 0.16)",
      "2": "0 12px 28px rgba(3, 10, 12, 0.24)"
    },
    "backdrop": "blur(18px)"
  },
  "styleProfile": {
    "name": "Signal",
    "prompt": "Compact telemetry dashboard with crisp dark contrast, sharper surfaces, and luminous accents."
  },
  "springPhysics": { "presets": { "snappy": { "tension": 320, "friction": 24 }, "gentle": { "tension": 180, "friction": 20 } } },
  "motionChoreography": { "sequences": { "listEnter": { "stagger": 18, "order": "forward" } } },
  "structuralMotif": {
    "default": "topbar",
    "intents": { "navigation": "topbar", "primaryAction": "floating-action-button", "utilityBar": "command-palette" }
  },
  "imageFilter": { "presets": { "telemetry": { "duotone": ["#071012", "#34d399"] } } },
  "preference": { "priority": ["user", "system", "accessibility", "brand"] },
  "constraint": { "contrast": 4.5, "focusRing": "2px solid #34d399", "touchTarget": 44 },
  "tokens": {
    "radius.md": "0.5rem",
    "color.secondary": "#38bdf8"
  }
}
