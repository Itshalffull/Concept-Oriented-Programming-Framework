# Propagate SchemaTemplate.properties blob into real Property/set calls on the instantiated Schema.
# When a user applies a template via SchemaTemplate/apply, the template's properties JSON object
# (containing displayWidget, compilationProvider, childSchema, defaultTemplate, schemaIcon,
# schemaColor) must be materialized as Property concept state so that:
#   - Tier 1b routing (block-editor navigation) activates for schemas with displayWidget set
#   - SchemaRegistersCompilationProvider fires for schemas with compilationProvider set
#   - content-native-schema.sync general syncs activate for childSchema/defaultTemplate
# See docs/plans/creation-ux-prd.md §Tier-1b, §CUX-08.

sync SchemaTemplateDisplayWidgetToProperty [eager] [recommended]
  purpose: "Set displayWidget Property on the instantiated schema so Tier 1b block-editor routing activates automatically"
when {
  SchemaTemplate/apply: [ name: ?template_name; targetSchemaName: ?schema ]
    => ok(schema: ?schema; properties: ?properties)
}
where {
  bind(?properties.displayWidget as ?displayWidget)
  filter(?displayWidget != "")
}
then {
  Property/set: [ entity: ?schema;
                  key: "displayWidget";
                  value: ?displayWidget ]
}

sync SchemaTemplateCompilationProviderToProperty [eager] [recommended]
  purpose: "Register compilationProvider Property on the instantiated schema so ContentCompiler dispatch and PluginRegistry wiring activate automatically"
when {
  SchemaTemplate/apply: [ name: ?template_name; targetSchemaName: ?schema ]
    => ok(schema: ?schema; properties: ?properties)
}
where {
  bind(?properties.compilationProvider as ?compilationProvider)
  filter(?compilationProvider != "")
}
then {
  Property/set: [ entity: ?schema;
                  key: "compilationProvider";
                  value: ?compilationProvider ]
}

sync SchemaTemplateChildSchemaToProperty [eager] [recommended]
  purpose: "Set childSchema Property on the instantiated schema so Outline child blocks receive the correct sub-schema overlay automatically"
