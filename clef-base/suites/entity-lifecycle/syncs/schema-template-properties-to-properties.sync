}
where {
  bind(?properties.childSchema as ?childSchema)
  filter(?childSchema != "")
}
then {
  Property/set: [ entity: ?schema;
                  key: "childSchema";
                  value: ?childSchema ]
}

sync SchemaTemplateDefaultTemplateToProperty [eager] [recommended]
  purpose: "Set defaultTemplate Property on the instantiated schema so new pages scaffolded from this schema get the correct default block tree"
when {
  SchemaTemplate/apply: [ name: ?template_name; targetSchemaName: ?schema ]
    => ok(schema: ?schema; properties: ?properties)
}
where {
  bind(?properties.defaultTemplate as ?defaultTemplate)
  filter(?defaultTemplate != "")
