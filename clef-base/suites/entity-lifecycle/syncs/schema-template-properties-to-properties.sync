sync SchemaTemplateSchemaIconToProperty [eager] [recommended]
  purpose: "Persist the template's schemaIcon display hint as a Property so schema browsers and navigation chrome can render the correct icon without a separate lookup"
when {
  SchemaTemplate/apply: [ name: ?template_name; targetSchemaName: ?schema ]
    => ok(schema: ?schema; properties: ?properties)
}
where {
  bind(?properties.schemaIcon as ?schemaIcon)
  filter(?schemaIcon != "")
}
then {
  Property/set: [ entity: ?schema;
                  key: "schemaIcon";
                  value: ?schemaIcon ]
}

sync SchemaTemplateSchemaColorToProperty [eager] [recommended]
  purpose: "Persist the template's schemaColor display hint as a Property so schema browsers and navigation chrome can render the correct accent color without a separate lookup"
when {
  SchemaTemplate/apply: [ name: ?template_name; targetSchemaName: ?schema ]
    => ok(schema: ?schema; properties: ?properties)
}
where {
  bind(?properties.schemaColor as ?schemaColor)
  filter(?schemaColor != "")
}
then {
  Property/set: [ entity: ?schema;
                  key: "schemaColor";
                  value: ?schemaColor ]
}
