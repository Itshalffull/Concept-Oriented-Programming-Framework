# Permission views for the governance permissions system.

# === Permissions by Subject View ===
# All permission grants grouped by subject (person/role/circle/process).

sync RegisterPermissionsBySubjectDataSource [eager]
  purpose { Data source for permissions grouped by subject. }
when {
  Schema/defineSchema: [schema: "circle"; fields: ?fields]
    => ok()
}
then {
  DataSourceSpec/create: [name: "permissions-by-subject-source"; config: "{\"concept\":\"Permission\",\"joinSchema\":true}"]
}

sync RegisterPermissionsBySubjectGroup [eager]
  purpose { Group permissions by subject type. }
when {
  Schema/defineSchema: [schema: "circle"; fields: ?fields]
    => ok()
}
then {
  GroupSpec/create: [name: "permissions-by-subject-group"; config: "{\"groupBy\":\"who_type\",\"order\":\"asc\"}"]
}

sync RegisterPermissionsBySubjectPresentation [eager]
  purpose { Table presentation for permissions by subject. }
when {
  Schema/defineSchema: [schema: "circle"; fields: ?fields]
    => ok()
}
then {
  PresentationSpec/create: [name: "permissions-by-subject-presentation"; displayType: "table"; hints: "{\"groupHeaders\":true,\"expandableGroups\":true}"]
}

sync RegisterPermissionsBySubjectView [eager]
  purpose { Register permissions by subject ViewShell. }
when {
  Schema/defineSchema: [schema: "circle"; fields: ?fields]
    => ok()
}
then {
  ViewShell/create: [name: "permissions-by-subject"; dataSource: "permissions-by-subject-source"; filter: ""; sort: ""; group: "permissions-by-subject-group"; projection: ""; presentation: "permissions-by-subject-presentation"; interaction: ""]
}

# === Permissions by Resource View ===

sync RegisterPermissionsByResourceDataSource [eager]
