}

# === Effective Permissions View ===
# For a given user, show all resolved effective permissions.

sync RegisterEffectivePermissionsDataSource [eager]
  purpose { Data source for effective permissions of a user. }
when {
  Schema/defineSchema: [schema: "circle"; fields: ?fields]
    => ok()
}
then {
  DataSourceSpec/create: [name: "effective-permissions-source"; config: "{\"concept\":\"Permission\",\"filter\":{\"resolved\":true},\"joinSchema\":true}"]
}

sync RegisterEffectivePermissionsPresentation [eager]
  purpose { Table presentation for effective permissions. }
when {
  Schema/defineSchema: [schema: "circle"; fields: ?fields]
    => ok()
}
then {
  PresentationSpec/create: [name: "effective-permissions-presentation"; displayType: "table"; hints: "{\"showResolutionChain\":true,\"highlightDirect\":true}"]
}

sync RegisterEffectivePermissionsView [eager]
  purpose { Register effective permissions ViewShell. }
when {
  Schema/defineSchema: [schema: "circle"; fields: ?fields]
    => ok()
}
then {
  ViewShell/create: [name: "effective-permissions"; dataSource: "effective-permissions-source"; filter: ""; sort: ""; group: ""; projection: ""; presentation: "effective-permissions-presentation"; interaction: ""]
}
