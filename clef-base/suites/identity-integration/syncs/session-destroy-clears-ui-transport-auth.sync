# Identity to ui-app transport wiring.
# When the active session is destroyed, clear the shell transport
# auth state so future requests do not reuse stale credentials.

sync SessionDestroyClearsUiTransportAuth [eager]
  purpose: "When a session is destroyed, clear the ui-app transport auth state so stale credentials are not reused"
when {
  Session/destroy: [ session: ?session ]
    => [ session: ?session ]
}
then {
  Transport/clearAuth: [ transport: "clef-base-transport" ]
}
