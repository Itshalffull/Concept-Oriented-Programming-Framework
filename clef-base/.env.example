CLEF_BASE_ADMIN_USERNAME=admin
CLEF_BASE_ADMIN_PASSWORD=change-me-now
CLEF_BASE_AUTH_PROVIDER=local
CLEF_BASE_PUBLIC_TITLE=Set up Clef Base
CLEF_BASE_PUBLIC_BODY=Clef Base starts with a single administrator account defined in environment variables.\n\nSign in with the seeded administrator account and open Access to create editors, viewers, and custom permissions.\n\nSet KV_REST_API_URL and KV_REST_API_TOKEN for persistent identity storage.
