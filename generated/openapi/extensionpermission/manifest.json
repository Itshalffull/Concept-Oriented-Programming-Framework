  "graphqlSchema": "type ExtensionPermissionState {\n  \"\"\"All ps in this concept\"\"\"\n  ps: [ID!]!\n}\n\ntype ExtensionPermissionEntry {\n  p: ID!\n  name: String!\n  scope: String!\n  status: String!\n  extensionId: String!\n  grants: String!\n}\n\nextend type Query {\n  extensionpermission_entry(p: ID!): ExtensionPermissionEntry\n  extensionpermission_entries: [ExtensionPermissionEntry!]!\n}\n\ntype ExtensionPermissionPermissions {\n  p: ID!\n  value: ID!\n}",
