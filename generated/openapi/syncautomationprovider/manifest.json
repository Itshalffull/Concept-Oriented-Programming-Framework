  "invariants": [
    {
      "description": "invariant 1: after register, define, validate, and activate, the sync lifecycle completes",
      "setup": [
        {
          "action": "register",
          "inputs": [],
          "expectedVariant": "ok",
          "expectedOutputs": [
            {
              "name": "provider_name",
              "value": {
                "kind": "literal",
                "value": "sync"
              }
            }
          ]
        },
        {
          "action": "define",
          "inputs": [
            {
              "name": "name",
              "value": {
                "kind": "literal",
                "value": "auto-tag"
              }
            },
            {
              "name": "source_text",
              "value": {
                "kind": "literal",
                "value": "sync AutoTag [eager] ..."
              }
            },
            {
              "name": "author",
              "value": {
                "kind": "literal",
                "value": "admin"
              }
            }
          ],
          "expectedVariant": "ok",
          "expectedOutputs": [
            {
              "name": "sync_def",
              "value": {
                "kind": "variable",
                "name": "sd"
              }
            }
          ]
        },
        {
          "action": "validate",
          "inputs": [
            {
              "name": "sync_def",
              "value": {
                "kind": "variable",
                "name": "sd"
              }
            }
          ],
          "expectedVariant": "ok",
          "expectedOutputs": [
            {
              "name": "sync_def",
              "value": {
                "kind": "variable",
                "name": "sd"
              }
            }
          ]
        }
      ],
      "assertions": [
        {
          "action": "activate",
          "inputs": [
            {
              "name": "sync_def",
              "value": {
                "kind": "variable",
                "name": "sd"
              }
