  "graphqlSchema": "type ProcessEventState {\n  \"\"\"All es in this concept\"\"\"\n  es: [ID!]!\n}\n\ntype ProcessEventEntry {\n  e: ID!\n  run_ref: String!\n  event_type: String!\n  step_ref: String!\n  actor_ref: String!\n  payload: String!\n  timestamp: String!\n  sequence_num: Int!\n}\n\nextend type Query {\n  processevent_entry(e: ID!): ProcessEventEntry\n  processevent_entries: [ProcessEventEntry!]!\n}\n\ntype ProcessEventEvents {\n  e: ID!\n  value: ID!\n}",
