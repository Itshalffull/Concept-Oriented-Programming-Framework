  "graphqlSchema": "type AssertionState {\n  \"\"\"All ts in this concept\"\"\"\n  ts: [ID!]!\n}\n\ntype AssertionEntry {\n  t: ID!\n  name: String!\n  constraint: String!\n  severity: String!\n  error_message: String!\n  max_retries: Int!\n  retry_count: Int!\n  attached_to: String!\n}\n\nextend type Query {\n  assertion_entry(t: ID!): AssertionEntry\n  assertion_entries: [AssertionEntry!]!\n}\n\ntype AssertionAssertions {\n  t: ID!\n  value: ID!\n}",
