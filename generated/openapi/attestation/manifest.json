  "graphqlSchema": "type AttestationState {\n  \"\"\"All as in this concept\"\"\"\n  as: [ID!]!\n}\n\ntype AttestationEntry {\n  a: ID!\n  schema: String!\n  attester: String!\n  recipient: String!\n  data: String!\n  createdAt: String!\n  expiry: String!\n  revoked: Boolean!\n}\n\nextend type Query {\n  attestation_entry(a: ID!): AttestationEntry\n  attestation_entries: [AttestationEntry!]!\n}\n\ntype AttestationAttestations {\n  a: ID!\n  value: ID!\n}",
