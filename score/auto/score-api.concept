# @fixtures-added
@version(1)
concept ScoreApi [Q] {

  purpose {
    Unified facade over the five Score suites (parse, symbol, semantic,
    analysis, discovery) providing a single LLM-friendly surface for
    querying any Clef project's structure, symbols, semantics, data
    flows, and search indexes. Every Clef app gets ScoreApi registered
    automatically — LLMs can immediately ask questions about the
    codebase without configuration. Actions are designed for natural
    language invocation: parameter names read as English, results are
    structured for tool-use consumption, and error variants include
    actionable suggestions.
  }

  state {
    queries: set Q
    queryState {
      kind: Q -> String
      input: Q -> String
      result: Q -> String
      timestamp: Q -> DateTime
    }
    indexes {
      conceptCount: Q -> Int
      symbolCount: Q -> Int
      fileCount: Q -> Int
      syncCount: Q -> Int
      lastIndexed: Q -> DateTime
    }
  }

  actions {
    // ─── Structural Queries (Parse Layer) ───────────────────

    action listFiles(pattern: String) {
      -> ok(files: list { path: String, language: String, role: String, size: Int }) {
        List all files in the project matching a glob pattern.
        Returns path, detected language, role (source, generated,
        config, test, doc), and file size. Use "*" for all files.
      }
      -> ok(pattern: String) {
        No files match the given pattern.
      }
      fixture list_all { pattern: "*" }
      fixture list_empty { pattern: "" } -> error
    }

    action getFileTree(path: String, depth: Int) {
      -> ok(tree: String, fileCount: Int, dirCount: Int) {
        Get a hierarchical tree view of the project starting at
        the given path. Depth controls recursion level (0 = full).
        Tree is formatted as an indented text tree suitable for
        display in chat or tool output.
      }
      -> ok(path: String) {
        The specified path does not exist in the project.
      }
      fixture tree_root { path: ".", depth: 2 } after list_all
      fixture tree_missing { path: "/nonexistent", depth: 0 } -> error
    }

    action getFileContent(path: String) {
      -> ok(content: String, language: String, definitions: list String) {
        Read a file's content along with its detected language
        and the names of top-level definitions it contains.
      }
      -> ok(path: String) {
        File does not exist in the project.
      }
      fixture get_handler { path: "handlers/ts/app/flag.handler.ts" } after list_all
      fixture get_missing { path: "" } -> error
    }

    action getDefinitions(path: String) {
      -> ok(definitions: list { name: String, kind: String, line: Int, span: String }) {
        Extract all definition units from a file — functions,
        classes, types, concept actions, sync rules, etc. Each
        entry includes the definition name, its kind, the line
        number, and the source span.
      }
      -> ok(path: String) {
        File does not exist or has not been parsed.
      }
      fixture get_defs { path: "handlers/ts/app/flag.handler.ts" } after list_all
      fixture get_defs_empty { path: "" } -> error
    }

    action matchPattern(pattern: String, language: String) {
      -> ok(matches: list { file: String, line: Int, text: String, context: String }) {
        Run a structural pattern query (tree-sitter query syntax)
        across all files of the given language. Returns matching
        locations with surrounding context.
      }
      -> ok(pattern: String, error: String) {
        The pattern syntax is invalid for the given language.
      }
      fixture match_fns { pattern: "(function_declaration) @fn", language: "typescript" } after list_all
      fixture match_empty { pattern: "", language: "typescript" } -> error
    }

    // ─── Symbol Queries (Symbol Layer) ──────────────────────

    action findSymbol(name: String) {
      -> ok(symbols: list { name: String, kind: String, file: String, line: Int, scope: String }) {
        Find all symbols matching the given name. Returns the
        symbol kind (function, type, concept, action, field, etc.),
        defining file, line number, and enclosing scope.
      }
      -> ok(name: String) {
        No symbols match the given name. Consider using search
        for fuzzy matching.
      }
      fixture find_flag { name: "flagHandler" } after list_all
      fixture find_empty { name: "" } -> error
    }

    action getReferences(symbol: String) {
      -> ok(definition: { file: String, line: Int }, references: list { file: String, line: Int, kind: String }) {
        Find all references to a symbol across the project.
        Returns the definition location and all reference
        locations with their reference kind (read, write, call,
        import, type-use).
      }
      -> ok(symbol: String) {
        Symbol not found. Check spelling or use findSymbol first.
      }
      fixture refs_flag { symbol: "flagHandler" } after list_all
      fixture refs_empty { symbol: "" } -> error
    }

    action getScope(file: String, line: Int) {
      -> ok(scope: String, symbols: list { name: String, kind: String }, parent: option String) {
        Get the scope at a specific file location. Returns the
        scope name, all symbols visible in that scope, and the
        parent scope if any.
      }
      -> ok(file: String) {
        File not found or has not been analyzed.
      }
      fixture scope_handler { file: "handlers/ts/app/flag.handler.ts", line: 10 } after list_all
      fixture scope_empty { file: "", line: 0 } -> error
    }

    action getRelationships(symbol: String) {
      -> ok(relationships: list { from: String, to: String, kind: String, file: String }) {
        Get typed relationships involving a symbol — implements,
        extends, overrides, calls, imports, depends-on, etc.
      }
      -> ok(symbol: String) {
        Symbol not found.
      }
      fixture rels_flag { symbol: "flagHandler" } after list_all
      fixture rels_empty { symbol: "" } -> error
    }

    // ─── Semantic Queries (Semantic Layer) ──────────────────

    action listConcepts() {
      -> ok(concepts: list { name: String, purpose: String, actions: list String, stateFields: list String, file: String }) {
        List all concepts in the project with their purpose,
        action names, state field names, and defining file path.
        This is the primary entry point for understanding a
        Clef application's architecture.
      }
      fixture valid {} after list_all
    }

    action getConcept(name: String) {
      -> ok(concept: { name: String, purpose: String, typeParams: list String, actions: list { name: String, params: list String, variants: list String }, stateFields: list { name: String, type: String, relation: String }, invariants: list String, file: String }) {
        Get complete details of a concept — its purpose, type
        parameters, actions with params and variants, state
        fields with types and relation groups, invariants, and
        source file.
      }
      -> ok(name: String) {
        Concept not found. Use listConcepts to see available concepts.
      }
      fixture get_flag { name: "Flag" } after list_all
      fixture get_missing_2 { name: "" } -> error
    }

    action getAction(concept: String, action: String) {
      -> ok(action: { name: String, params: list { name: String, type: String }, variants: list { name: String, fields: list String, prose: String }, description: String }) {
        Get full details of a concept action — parameters with
        types, all variants with their fields and prose, and the
        action description.
      }
      -> ok(concept: String, action: String) {
        Action not found on the given concept.
      }
      fixture get_flag_action { concept: "Flag", action: "flag" } after list_all
      fixture get_missing_action { concept: "", action: "" } -> error
    }

    action listSyncs() {
      -> ok(syncs: list { name: String, annotation: String, triggers: list String, effects: list String, file: String }) {
        List all sync rules in the project with their annotation
        (eager, eventual, local), trigger patterns, effect actions,
        and source file.
      }
      fixture valid_2 {} after list_all
    }

    action getSync(name: String) {
      -> ok(sync: { name: String, annotation: String, when: list { concept: String, action: String, bindings: list String }, where: list String, then: list { concept: String, action: String, bindings: list String }, file: String }) {
        Get full details of a sync rule — the when clause with
        pattern-matched concept/action/bindings, optional where
        clause with queries and filters, and then clause with
        invoked concept/action/bindings.
      }
      -> ok(name: String) {
        Sync not found. Use listSyncs to see available syncs.
      }
      fixture get_sync { name: "onUserCreate" } after list_all
      fixture get_missing_sync { name: "" } -> error
    }

    action getFlow(startConcept: String, startAction: String) {
      -> ok(flow: list { step: Int, concept: String, action: String, sync: String, variant: String }) {
        Trace the static flow graph starting from a concept
        action. Shows the chain of sync firings and concept
        action invocations that would occur. Useful for
        understanding side effects and cross-concept coordination.
      }
      -> ok(concept: String, action: String) {
        Starting concept/action not found.
      }
      fixture flow_create { startConcept: "User", startAction: "create" } after list_all
      fixture flow_empty { startConcept: "", startAction: "" } -> error
    }

    // ─── Handler Queries (Implementation Layer) ─────────────

    action getHandler(concept: String, language: String) {
      -> ok(handler: { concept: String, language: String, sourceFile: String, actionMethods: list { name: String, startLine: Int, endLine: Int }, dependencies: list String, storageCollections: list String }) {
        Get the handler implementation for a concept in a given
        language. Returns source file, action method locations,
        dependency list, and storage collection usage.
      }
      -> ok(concept: String, language: String) {
        No handler registered for this concept and language.
      }
      fixture get_handler_ts { concept: "Flag", language: "typescript" } after list_all
      fixture get_handler_missing { concept: "nonexistent", language: "typescript" } -> error
    }

    action getActionSource(concept: String, action: String) {
      -> ok(source: String, file: String, startLine: Int, endLine: Int) {
        Get the source code of a specific action method in the
        concept's handler. Returns the method body and its exact
        file location.
      }
      -> ok(concept: String) {
        No handler registered for this concept.
      }
      -> ok(concept: String, action: String) {
        Handler exists but does not implement this action.
      }
      fixture get_source { concept: "Flag", action: "flag" } after list_all
      fixture get_source_missing { concept: "nonexistent", action: "x" } -> error
    }

    action listHandlers() {
      -> ok(handlers: list { concept: String, language: String, sourceFile: String, actionCount: Int, lineCount: Int }) {
        List all registered handlers with their concept, language,
        source file, number of implemented actions, and line count.
      }
      fixture valid_3 {} after list_all
    }

    action implementationGaps() {
      -> ok(gaps: list { concept: String, action: String, declaredIn: String }) {
        Find all concept actions that are declared in specs but
        have no handler implementation. Returns concept name,
        action name, and the spec file where it's declared.
      }
      -> ok() {
        Every declared action has a handler implementation.
      }
      fixture valid_4 {} after list_all
    }

    action resolveStackTrace(stackTrace: String) {
      -> ok(frames: list { file: String, line: Int, col: Int, handler: option String, concept: option String, actionMethod: option String, astNode: option { kind: String, text: String, startLine: Int, endLine: Int }, astAncestors: option list { kind: String, startLine: Int, endLine: Int }, symbol: String }) {
        Parse a stack trace and resolve each frame to handler
        entities, concept names, action methods, and exact AST
        nodes where possible. For frames within handlers, astNode
        is the precise code construct at that position (e.g.,
        AwaitExpression, ReturnStatement, IfStatement) and
        astAncestors is the chain up to the method root.
      }
      fixture resolve_trace { stackTrace: "Error\n    at flag (handlers/ts/app/flag.handler.ts:14:5)" } after list_all
      fixture resolve_empty { stackTrace: "" } -> error
    }

    // ─── Widget/Theme Implementation Queries ──────────────

    action getWidgetImpl(widget: String, framework: String) {
      -> ok(impl: { widget: String, framework: String, sourceFile: String, componentName: String, renderedParts: list String, propsInterface: String }) {
        Get the generated widget implementation for a given
        framework. Returns component name, rendered parts mapping,
        and props interface.
      }
      -> ok(widget: String, framework: String) {
        No widget implementation for this widget and framework.
      }
      fixture get_react_dialog { widget: "dialog", framework: "react" } after list_all
      fixture get_missing_impl { widget: "nonexistent", framework: "react" } -> error
    }

    action getThemeImpl(theme: String, platform: String) {
      -> ok(impl: { theme: String, platform: String, sourceFile: String, tokenCount: Int }) {
        Get the generated theme implementation for a given
        platform. Returns source file and token count.
      }
      -> ok(theme: String, platform: String) {
        No theme implementation for this theme and platform.
      }
      fixture get_css_light { theme: "light", platform: "css" } after list_all
      fixture get_missing_theme { theme: "nonexistent", platform: "css" } -> error
    }

    // ─── Deployment Queries (Deployment Layer) ──────────────

    action getDeployment(name: String) {
      -> ok(deployment: { name: String, appVersion: String, runtimes: list { name: String, type: String, transport: String, storage: String, concepts: list String }, sourceFile: String }) {
        Get a deployment manifest's topology — runtimes, concept
        assignments, and transport/storage bindings.
      }
      -> ok(name: String) {
        No deployment with this name.
      }
      fixture get_prod { name: "conduit-prod" } after list_all
      fixture get_missing_deploy { name: "nonexistent" } -> error
    }

    action getDeploymentTopology(name: String) {
      -> ok(graph: { nodes: list { id: String, kind: String, label: String }, edges: list { from: String, to: String, transport: String } }) {
        Get the full deployment topology as a traversable graph.
      }
      -> ok(name: String) {
        No deployment with this name.
      }
      fixture get_topo { name: "conduit-prod" } after list_all
      fixture get_topo_missing { name: "nonexistent" } -> error
    }

    action getDeploymentHealth(name: String) {
      -> ok(runtimes: list { name: String, status: String, uptime: String }, transports: list { from: String, to: String, status: String, latencyP99Ms: Int }, syncDeliveryRate: Float) {
        Get current operational health of a deployment.
      }
      -> ok(name: String) {
        No deployment with this name.
      }
      fixture get_health { name: "conduit-prod" } after list_all
      fixture get_health_missing { name: "nonexistent" } -> error
    }

    // ─── Suite Queries (Suite Layer) ──────────────────────

    action listSuites() {
      -> ok(suites: list { name: String, version: String, conceptCount: Int, syncCount: Int, file: String }) {
        List all registered suites.
      }
      fixture valid_5 {} after list_all
    }

    action getSuite(name: String) {
      -> ok(suite: { name: String, version: String, description: String, concepts: list { name: String, spec: String }, syncs: list { name: String, tier: String }, dependencies: list String, file: String }) {
        Get full details of a suite manifest.
      }
      -> ok(name: String) {
        No suite with this name.
      }
      fixture get_suite { name: "identity" } after list_all
      fixture get_suite_missing { name: "nonexistent" } -> error
    }

    // ─── Interface Queries (Interface Layer) ──────────────

    action listInterfaces() {
      -> ok(interfaces: list { name: String, targets: list String, conceptCount: Int, endpointCount: Int, file: String }) {
        List all registered interface manifests.
      }
      fixture valid_6 {} after list_all
    }

    action getEndpoints(interface: String, target: String) {
      -> ok(endpoints: list { method: String, path: String, concept: String, action: String }) {
        List all generated endpoints for a target (rest, graphql, grpc).
      }
      -> ok(interface: String) {
        No interface with this name.
      }
      fixture get_rest_endpoints { interface: "conduit-api", target: "rest" } after list_all
      fixture get_endpoints_missing { interface: "nonexistent", target: "rest" } -> error
    }

    action traceEndpoint(target: String, path: String, method: String) {
      -> ok(concept: String, action: String, handler: String, sourceFile: String) {
        Trace an API endpoint back to the concept, action, and
        handler that implements it.
      }
      -> ok() {
        No endpoint matches.
      }
      fixture trace_users { target: "rest", path: "/api/users", method: "POST" } after list_all
      fixture trace_empty { target: "", path: "", method: "" } -> error
    }

    // ─── Analysis Queries (Analysis Layer) ──────────────────

    action getDependencies(symbol: String) {
      -> ok(directDeps: list { name: String, kind: String, file: String }, transitiveDeps: list { name: String, kind: String, file: String }) {
        Get direct and transitive dependencies of a symbol.
        Shows what a symbol depends on (imports, calls, reads).
      }
      -> ok(symbol: String) {
        Symbol not found.
      }
      fixture deps_symbol { symbol: "flagHandler" } after list_all
      fixture deps_empty { symbol: "" } -> error
    }

    action getDependents(symbol: String) {
      -> ok(directDeps: list { name: String, kind: String, file: String }, transitiveDeps: list { name: String, kind: String, file: String }) {
        Get direct and transitive dependents of a symbol.
        Shows what depends on this symbol (reverse dependencies).
        Useful for impact analysis.
      }
      -> ok(symbol: String) {
        Symbol not found.
      }
      fixture dependents { symbol: "flagHandler" } after list_all
      fixture dependents_empty { symbol: "" } -> error
    }

    action getImpact(file: String) {
      -> ok(directImpact: list { file: String, reason: String }, transitiveImpact: list { file: String, reason: String }) {
        Analyze the impact of changing a file. Returns directly
        affected files and transitively affected files with the
        reason for impact (import, sync reference, type dependency,
        generated-from, etc.).
      }
      -> ok(file: String) {
        File not found.
      }
      fixture impact_handler { file: "handlers/ts/app/flag.handler.ts" } after list_all
      fixture impact_empty { file: "" } -> error
    }

    action getDataFlow(from: String, to: String) {
      -> ok(paths: list { hops: list { symbol: String, file: String, kind: String }, length: Int }) {
        Find data flow paths between two symbols. Shows how data
        moves from one point to another through the program.
        Useful for understanding action chains and sync propagation.
      }
      -> ok(from: String, to: String) {
        No data flow path exists between the given symbols.
      }
      fixture flow_path { from: "User/create", to: "Email/send" } after list_all
      fixture flow_empty_2 { from: "", to: "" } -> error
    }

    // ─── Discovery Queries (Discovery Layer) ────────────────

    action search(query: String, limit: Int) {
      -> ok(results: list { name: String, kind: String, file: String, line: Int, score: Float, snippet: String }) {
        Search the project using natural language. Combines
        semantic embedding similarity, trigram text search, and
        symbol-aware indexing for best results. Returns ranked
        matches with relevance score and context snippet.
      }
      -> ok(query: String) {
        No results found. Try broader terms or check listConcepts
        for available concepts.
      }
      fixture search_user { query: "user authentication", limit: 10 } after list_all
      fixture search_empty { query: "", limit: 10 } -> error
    }

    action explain(symbol: String) {
      -> ok(summary: String, kind: String, definedIn: String, usedBy: list String, relationships: list String) {
        Generate a natural language explanation of a symbol —
        what it is, where it's defined, what uses it, and its
        key relationships. Designed for LLM consumption: the
        summary is a complete sentence suitable for embedding
        in a response.
      }
      -> ok(symbol: String) {
        Symbol not found.
      }
      fixture explain_flag { symbol: "Flag" } after list_all
      fixture explain_empty { symbol: "" } -> error
    }

    // ─── View Queries (View Layer) ──────────────────────────

    action listViews() {
      -> ok(views: String) {
        Return all indexed ViewEntity entries as a JSON array, each
        containing name, shellRef, purposeText, and purity.
      }
      fixture list_views {} after list_all
    }

    action getView(name: String) {
      -> ok(view: String) {
        Return the full ViewEntity record for the named view as JSON,
        including all analysis fields (purity, invokedActions,
        projectedFields, filterFields, invariants).
      }
      -> notfound(message: String) {
        No view with this name is indexed.
      }
      fixture get_view_existing { name: "content-list" } after list_all
      fixture get_view_missing { name: "nonexistent" } -> notfound
    }

    action findViewsByShell(shellRef: String) {
      -> ok(views: String) {
        Return all views referencing this ViewShell as a JSON array.
      }
      fixture find_views_by_shell { shellRef: "content-list" } after list_all
    }

    action findViewsByPurity(purity: String) {
      -> ok(views: String) {
        Return all views with the given purity classification.
      }
      fixture find_views_by_purity { purity: "read-only" } after list_all
    }

    action findViewsByInvokedAction(action: String) {
      -> ok(views: String) {
        Return all views whose invokedActions include the given
        concept/action pair.
      }
      fixture find_views_by_action { action: "Task/escalate" } after list_all
    }

    // ─── Index Management ───────────────────────────────────

    action status() {
      -> ok(indexed: Bool, conceptCount: Int, symbolCount: Int, fileCount: Int, syncCount: Int, handlerCount: Int, widgetImplCount: Int, themeImplCount: Int, suiteCount: Int, deploymentCount: Int, interfaceCount: Int, viewCount: Int, lastIndexed: DateTime) {
        Get the current status of the Score index. Returns
        counts of indexed entities and the last indexing time.
      }
      fixture valid_7 {} after list_all
    }

    action reindex() {
      -> ok(conceptCount: Int, symbolCount: Int, fileCount: Int, syncCount: Int, handlerCount: Int, widgetImplCount: Int, themeImplCount: Int, suiteCount: Int, deploymentCount: Int, interfaceCount: Int, viewCount: Int, duration: Int) {
        Force a full reindex of the project. Parses all files,
        extracts symbols, builds semantic graph, indexes handler
        implementations, widget implementations, theme implementations,
        view manifests, computes analysis overlays, and generates
        embeddings. Returns counts and duration in milliseconds.
      }
      -> ok(startedAt: DateTime) {
        A reindex is already in progress.
      }
      fixture valid_8 {} after list_all
    }
  }

  invariant {
  example "reindex populates query indexes": {
    after reindex() -> ok(conceptCount: c, symbolCount: s, fileCount: f, syncCount: y, handlerCount: h, widgetImplCount: w, themeImplCount: t2, viewCount: vc, duration: d)
    then status() -> ok(indexed: true, conceptCount: c, symbolCount: s, fileCount: f, syncCount: y, handlerCount: h, widgetImplCount: w, themeImplCount: t2, viewCount: vc, lastIndexed: t)
    and listConcepts() -> ok(concepts: concepts)
    and listSyncs() -> ok(syncs: syncs)
    and listHandlers() -> ok(handlers: handlers)
    and listViews() -> ok(views: views)
  }

  always "every queries entry has kind": {
    forall q in queries:
      q.kind != none
  }

  never "empty kind in queries": {
    exists q in queries:
      q.kind = ""
  }

  action listFiles {
    requires: pattern != ""
    ensures ok: pattern != none
  }
  }
}
