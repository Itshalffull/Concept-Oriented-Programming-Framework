# @fixtures-added
@version(1)
concept ScoreIndex [X] {

  purpose {
    Materialized index backing ScoreApi queries. Maintains
    denormalized views of the five Score layers (parse, symbol,
    semantic, analysis, discovery) optimized for fast LLM-friendly
    lookups. Rebuilt incrementally as project files change.
    Auto-registered as a built-in concept in every Clef runtime.
  }

  state {
    indexes: set X
    meta {
      kind: X -> String
      entityCount: X -> Int
      lastUpdated: X -> DateTime
    }
    concepts {
      conceptName: X -> String
      purpose: X -> String
      actions: X -> list String
      stateFields: X -> list String
      file: X -> String
    }
    syncs {
      syncName: X -> String
      annotation: X -> String
      triggers: X -> list String
      effects: X -> list String
      file: X -> String
    }
    symbols {
      symbolName: X -> String
      symbolKind: X -> String
      file: X -> String
      line: X -> Int
      scope: X -> String
    }
    files {
      filePath: X -> String
      language: X -> String
      role: X -> String
      definitions: X -> list String
    }
    handlers {
      handlerConcept: X -> String
      handlerLanguage: X -> String
      handlerFile: X -> String
      handlerActions: X -> list String
      handlerLineCount: X -> Int
    }
    widgetImpls {
      widgetImplWidget: X -> String
      widgetImplFramework: X -> String
      widgetImplFile: X -> String
      widgetImplComponent: X -> String
    }
    themeImpls {
      themeImplTheme: X -> String
      themeImplPlatform: X -> String
      themeImplFile: X -> String
      themeImplTokenCount: X -> Int
    }
    deployments {
      deploymentName: X -> String
      deploymentApp: X -> String
      deploymentRuntimes: X -> list String
      deploymentFile: X -> String
    }
    suiteManifests {
      suiteName: X -> String
      suiteVersion: X -> String
      suiteConcepts: X -> list String
      suiteSyncs: X -> list String
      suiteFile: X -> String
    }
    interfaces {
      interfaceName: X -> String
      interfaceTargets: X -> list String
      interfaceEndpointCount: X -> Int
      interfaceFile: X -> String
    }
  }

  actions {
    action upsertConcept(name: String, purpose: String, actions: list String, stateFields: list String, file: String) {
      -> ok(index: X) {
        Insert or update a concept entry in the index.
      }
      -> error(message: String) {
        Invalid concept data.
      }
      fixture upsert_user { name: "User", purpose: "Manage user accounts", file: "/specs/user.concept" }
      fixture upsert_empty { name: "" } -> error
    }

    action upsertSync(name: String, annotation: String, triggers: list String, effects: list String, file: String) {
      -> ok(index: X) {
        Insert or update a sync entry in the index.
      }
      -> error(message: String) {
        Invalid sync data.
      }
      fixture upsert_sync { name: "onUserCreate", annotation: "eager", file: "/specs/syncs.sync" }
      fixture upsert_sync_empty { name: "" } -> error
    }

    action upsertSymbol(name: String, kind: String, file: String, line: Int, scope: String) {
      -> ok(index: X) {
        Insert or update a symbol entry in the index.
      }
      -> error(message: String) {
        Invalid symbol data.
      }
      fixture upsert_fn { name: "handleCreate", kind: "function", file: "/src/handler.ts", line: 42 }
      fixture upsert_sym_empty { name: "" } -> error
    }

    action upsertFile(path: String, language: String, role: String, definitions: list String) {
      -> ok(index: X) {
        Insert or update a file entry in the index.
      }
      -> error(message: String) {
        Invalid file data.
      }
      fixture upsert_file { path: "/src/handler.ts", language: "typescript", role: "source" }
      fixture upsert_file_empty { path: "" } -> error
    }

    action upsertHandler(concept: String, language: String, file: String, actions: list String, lineCount: Int) {
      -> ok(index: X) {
        Insert or update a handler entry in the index.
      }
      -> error(message: String) {
        Invalid handler data.
      }
      fixture upsert_handler { concept: "Flag", language: "typescript", file: "/handlers/ts/flag.handler.ts", lineCount: 80 }
      fixture upsert_handler_empty { concept: "" } -> error
    }

    action upsertWidgetImpl(widget: String, framework: String, file: String, component: String) {
      -> ok(index: X) {
        Insert or update a widget implementation entry in the index.
      }
      -> error(message: String) {
        Invalid widget implementation data.
      }
      fixture upsert_widget { widget: "dialog", framework: "react", file: "/generated/Dialog.tsx", component: "Dialog" }
      fixture upsert_widget_empty { widget: "" } -> error
    }

    action upsertThemeImpl(theme: String, platform: String, file: String, tokenCount: Int) {
      -> ok(index: X) {
        Insert or update a theme implementation entry in the index.
      }
      -> error(message: String) {
        Invalid theme implementation data.
      }
      fixture upsert_theme { theme: "light", platform: "css", file: "/generated/light.css", tokenCount: 42 }
      fixture upsert_theme_empty { theme: "" } -> error
    }

    action upsertDeployment(name: String, app: String, runtimes: list String, file: String) {
      -> ok(index: X) {
        Insert or update a deployment entry in the index.
      }
      -> error(message: String) {
        Invalid deployment data.
      }
      fixture upsert_deploy { name: "conduit-prod", app: "conduit", file: "/deploy/prod.yaml" }
      fixture upsert_deploy_empty { name: "" } -> error
    }

    action upsertSuiteManifest(name: String, version: String, concepts: list String, syncs: list String, file: String) {
      -> ok(index: X) {
        Insert or update a suite manifest entry in the index.
      }
      -> error(message: String) {
        Invalid suite manifest data.
      }
      fixture upsert_suite { name: "identity", version: "1.0.0", file: "/suites/identity/suite.yaml" }
      fixture upsert_suite_empty { name: "" } -> error
    }

    action upsertInterface(name: String, targets: list String, endpointCount: Int, file: String) {
      -> ok(index: X) {
        Insert or update an interface entry in the index.
      }
      -> error(message: String) {
        Invalid interface data.
      }
      fixture upsert_iface { name: "conduit-api", endpointCount: 12, file: "/interfaces/api.yaml" }
      fixture upsert_iface_empty { name: "" } -> error
    }

    action removeByFile(path: String) {
      -> ok(removed: Int) {
        Remove all index entries associated with a file.
      }
      fixture remove_file { path: "/src/handler.ts" }
      fixture remove_empty { path: "" }
    }

    action clear() {
      -> ok(cleared: Int) {
        Clear all index entries. Used before a full reindex.
      }
      fixture valid {}
    }

    action stats() {
      -> ok(conceptCount: Int, syncCount: Int, symbolCount: Int, fileCount: Int, handlerCount: Int, widgetImplCount: Int, themeImplCount: Int, suiteCount: Int, deploymentCount: Int, interfaceCount: Int, lastUpdated: DateTime) {
        Return current index statistics.
      }
      fixture valid {}
    }
  }

  invariant {
  example "operational principle 1": {
    after upsertConcept(name: "Test", purpose: "A test concept", actions: a, stateFields: f, file: "/test.concept") -> ok(index: x)
    then stats() -> ok(conceptCount: c, syncCount: s, symbolCount: y, fileCount: f2, lastUpdated: t)
  }

  always "every indexes entry has conceptName": {
    forall x in indexes:
      x.conceptName != none
  }

  never "empty conceptName in indexes": {
    exists x in indexes:
      x.conceptName = ""
  }

  action upsertConcept {
    requires: name != ""
    ensures ok: name != none
  }
  }
}
