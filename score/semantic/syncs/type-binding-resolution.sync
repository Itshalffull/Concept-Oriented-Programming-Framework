// Resolve type parameter mappings when suite.yaml is parsed.
// Creates FieldMapping entries that bind concept type parameters
// to suite shared types, enabling cross-concept type unification.

sync TypeBindingResolutionSync [eager]
when {
  ContentParser/parse: [ file: ?suiteYaml ]
    => [ ]
}
where {
  filter(?suiteYaml pathMatches: "*/suite.yaml")
}
then {
  FieldMapping/create: [ sourceSchema: ?conceptTypeParam; targetSchema: ?suiteSharedType; direction: "bidirectional" ]
}
