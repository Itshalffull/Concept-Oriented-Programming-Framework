@version(1)
# @fixtures-added
concept TestEntity [T] {

  purpose {
    Queryable representation of test suites, conformance checks,
    and validation rules. Links tests to the concepts, syncs, handlers,
    and widgets they validate. Enables queries like "what tests cover
    User/create?", "which invariants are tested?", "what's the test
    coverage for this concept?", and "which tests are failing?"
  }

  state {
    tests: set T
    name: T -> String
    symbol: T -> String
    sourceFile: T -> String
    startLine: T -> Int
    endLine: T -> Int
    kind: T -> String
    targetEntity: T -> String
    targetAction: T -> String
    assertions: T -> String
    invariantRef: T -> String
    lastResult: T -> String
    lastDuration: T -> Int
  }

  capabilities {
    requires persistent-storage
  }

  actions {
    action register(name: String, sourceFile: String, kind: String, targetEntity: String) {
      -> ok(test: T) {
        Register a test. kind is one of: conformance, unit,
        integration, invariant, sync-chain, widget-render,
        theme-contrast, e2e. targetEntity is the concept, sync,
        handler, or widget being tested.
      }
      -> alreadyRegistered(existing: T) {
        A test with this name and file already exists.
      }

      fixture register_conformance_test { name: "User/create conformance", sourceFile: "tests/user.conformance.test.ts", kind: "conformance", targetEntity: "User" }
      fixture register_empty_name { name: "", sourceFile: "tests/empty.test.ts", kind: "unit", targetEntity: "User" } -> error
    }

    action get(name: String) {
      -> ok(test: T) {
        Retrieve a test entity by name.
      }
      -> notfound() {
        No test with this name exists.
      }

      fixture get_existing_test { name: "User/create conformance" }
      fixture get_nonexistent { name: "Nonexistent/test" } -> error
    }

    action findByEntity(entity: String) {
      -> ok(tests: String) {
        Return all tests targeting a given entity. Result as
        serialized JSON array of { name, kind, sourceFile, lastResult }.
      }

      fixture find_user_tests { entity: "User" }
      fixture find_untested_entity { entity: "Nonexistent" } -> error
    }

    action findByAction(concept: String, action: String) {
      -> ok(tests: String) {
        Return all tests covering a specific concept action.
        Result as serialized JSON array.
      }

      fixture find_user_create_tests { concept: "User", action: "create" }
      fixture find_untested_action { concept: "User", action: "nonexistentAction" } -> error
    }

    action findByKind(kind: String) {
      -> ok(tests: String) {
        Return all tests of a given kind. Result as serialized
        JSON array.
      }

      fixture find_conformance_tests { kind: "conformance" }
      fixture find_unknown_kind { kind: "nonexistent-kind" } -> error
    }

    action findFailing() {
      -> ok(tests: String) {
        Return all tests whose last result was failure. Result
        as serialized JSON array of { name, kind, targetEntity,
        sourceFile, errorMessage }.
      }
      -> allPassing() {
        All tests are passing.
      }

      fixture valid {}
      fixture failing_check_error {} -> error
    }

    action coverageReport(entity: String) {
      -> ok(report: String) {
        Return test coverage for an entity — which actions,
        variants, and invariants are tested vs untested. Result
        as serialized JSON { totalActions, testedActions,
        totalVariants, testedVariants, totalInvariants,
        testedInvariants, coveragePct }.
      }

      fixture coverage_user { entity: "User" }
      fixture coverage_nonexistent { entity: "Nonexistent" } -> error
    }

    action untestedActions() {
      -> ok(actions: String) {
        Return all concept actions that have no test coverage.
        Result as serialized JSON array of { concept, action,
        declaredIn }.
      }
      -> fullCoverage() {
        All actions have test coverage.
      }

      fixture valid {}
      fixture untested_check_error {} -> error
    }

    action untestedInvariants() {
      -> ok(invariants: String) {
        Return all declared invariants that have no test. Result
        as serialized JSON array of { concept, invariant, declaredIn }.
      }
      -> fullCoverage() {
        All invariants have test coverage.
      }

      fixture valid {}
      fixture untested_invariants_error {} -> error
    }

    action recordResult(test: T, result: String, duration: Int) {
      -> ok(test: T) {
        Record a test execution result. result is one of:
        pass, fail, skip, error.
      }

      fixture record_pass { test: "test-001", result: "pass", duration: 150 }
      fixture record_empty_result { test: "test-001", result: "", duration: 0 } -> error
    }
  }

  invariant {
  example "registered entity is retrievable": {
    after register(name: "User/create conformance", sourceFile: "tests/user.conformance.test.ts", kind: "conformance", targetEntity: "User") -> ok(test: t)
    then get(name: "User/create conformance") -> ok(test: t)
  }

  always "every tests entry has name": {
    forall t in tests:
      t.name != none
  }

  never "empty name in tests": {
    exists t in tests:
      t.name = ""
  }

  action register {
    requires: name != ""
    ensures ok: name != none
  }
  }
}
