# @fixtures-added
@version(1)
concept Metric [ME] {

  purpose {
    Track measurable values with thresholds, enabling KPI-based
    governance triggers and performance monitoring.
  }

  state {
    metrics: set ME
    name: ME -> String
    value: ME -> Float
    unit: ME -> option String
    source: ME -> String
    thresholds: ME -> list {
      level: String,
      operator: String,
      value: Float
    }
    history: ME -> list {
      value: Float,
      timestamp: DateTime
    }
    updatedAt: ME -> DateTime
  }

  capabilities {
    requires persistent-storage
  }

  actions {
    action define(name: String, unit: option String, aggregation: String) {
      -> defined(metric: ME) {
        A new metric is created with initial value 0.
      }

      fixture define_revenue { name: "quarterly-revenue", unit: "USD", aggregation: "sum" }
      fixture define_empty_name { name: "", unit: "", aggregation: "sum" }
    }

    action update(metric: ME, value: Float, source: String) {
      -> updated(metric: ME, previousValue: Float) {
        The metric value is updated and history is appended.
      }
      -> threshold_crossed(metric: ME, threshold: String, direction: String) {
        The update caused a threshold to be crossed.
      }

      fixture update_revenue { metric: "metric-001", value: 150000.0, source: "finance-api" } after define_revenue
      fixture update_nonexistent { metric: "metric-nonexistent", value: 0.0, source: "manual" } -> error
    }

    action setThreshold(metric: ME, threshold: Float, alertOnBreach: Bool) {
      -> threshold_set(metric: ME) {
        A threshold is added or updated.
      }

      fixture set_revenue_threshold { metric: "metric-001", threshold: 100000.0, alertOnBreach: true } after define_revenue
      fixture set_threshold_nonexistent { metric: "metric-nonexistent", threshold: 0.0, alertOnBreach: false } -> error
    }

    action evaluate(metric: ME) {
      -> within_bounds(metric: ME) {
        All thresholds are satisfied.
      }
      -> threshold_breached(metric: ME, breachedThresholds: String) {
        One or more thresholds are breached.
      }

      fixture evaluate_existing { metric: "metric-001" } after define_revenue
      fixture evaluate_nonexistent { metric: "metric-nonexistent" } -> error
    }
  }

  example "define-then-update": {

    after define(name: _, unit: _, aggregation: _) -> defined(metric: me)

        then update(metric: me, value: 50.0, source: _) -> updated(metric: me, previousValue: _)

  }


  always "valid-name" {

    forall me in metrics:

      me.name != none

  }

  never "orphaned-value" {

    exists me in metrics:

      me.value = none

  }

  action define {

    requires: name != ""

    ensures defined: name != none

  }
}
