# DisplayMode resolution — routes Renderer to the correct rendering strategy.
# When Renderer encounters a (schema, display_mode, entity) triple, resolve
# the DisplayMode to get the full configuration.

sync DisplayModeResolveStrategy [eager]
when {
  Renderer/render: [ schema: ?schema; display_mode: ?mode; entity: ?entity ]
}
where {
  DisplayMode: { ?dm schema: ?schema; mode_id: ?mode }
}
then {
  DisplayMode/get: [ mode: ?dm ]
}
