# @fixtures-added
@version(1)
concept FormalProperty [P] {

  purpose {
    Atomic formal claim about system behavior. Tracks proof status
    and links to Evidence artifacts. Kinds include invariant,
    precondition, postcondition, temporal, safety, and liveness.
    Properties target Clef symbols (concepts, actions, syncs).
  }

  state {
    properties: set P

    target_symbol: P -> String
    kind: P -> String
    property_text: P -> String
    formal_language: P -> String
    scope: P -> String
    status: P -> String
    ghost: P -> Bool
    dependencies: P -> list String

    metadata {
      created_at: P -> DateTime
      updated_at: P -> DateTime
      author: P -> option String
      priority: P -> String
    }
  }

  actions {

    action define(name: String, target_symbol: String, kind: String, expression: String, formal_language: String, scope: String, priority: String) {
      -> ok(property: P) {
        Creates new formal property in "unproven" status.
        kind: invariant | precondition | postcondition | temporal | safety | liveness
        formal_language: smtlib | tlaplus | alloy | lean | dafny | cvl
        scope: local | global | sync
        priority: required | recommended | optional
      }
      -> invalid(message: String) {
        Invalid kind, language, or malformed property text.
      }

      fixture valid_define { name: "hash-nonzero", target_symbol: "clef/concept/Password", kind: "invariant", expression: "forall p: Password | len(p.hash) > 0", formal_language: "smtlib", scope: "local", priority: "required" }
      fixture invalid_kind { name: "bad-prop", target_symbol: "clef/concept/User", kind: "bogus", expression: "true", formal_language: "smtlib", scope: "local", priority: "optional" } -> invalid
    }

    action prove(id: String, evidence_ref: String) {
      -> ok(id: String, status: String, evidence_ref: String) {
        Transitions from unproven to "proved". Links Evidence artifact.
      }
      -> notfound(id: String) {
        Property does not exist.
      }

      fixture valid_prove { id: $valid_define.property, evidence_ref: "ev-abc" } after valid_define
      fixture prove_missing { id: "nonexistent", evidence_ref: "ev-abc" } -> notfound
    }

    action refute(id: String, evidence_ref: String) {
      -> ok(id: String, status: String, evidence_ref: String) {
        Transitions to "refuted". Links Evidence counterexample artifact.
      }
      -> notfound(id: String) {
        Property does not exist.
      }

      fixture valid_refute { id: $valid_define.property, evidence_ref: "ev-counter" } after valid_define
      fixture refute_missing { id: "nonexistent", evidence_ref: "ev-counter" } -> notfound
    }

    action check(id: String, solver: option String) {
      -> ok(id: String, current_status: String, check_result: String, solver: String) {
        Dispatches to SolverProvider. Returns updated status.
      }
      -> notfound(id: String) {
        Property does not exist.
      }

      fixture valid_check { id: $valid_define.property, solver: "z3" } after valid_define
      fixture check_missing { id: "nonexistent", solver: "z3" } -> notfound
    }

    action synthesize(target_symbol: String, intent_ref: String, formal_language: option String) {
      -> ok(intent_ref: String, property_ids: String, count: Int) {
        Generates formal properties from Intent.operationalPrinciples.
        Uses pattern matching against SpecificationSchema library,
        or LLM generation via sync to AgentLoop.
      }
      -> invalid(message: String) {
        Intent not found or has no principles.
      }

      fixture valid_synthesize { target_symbol: "clef/concept/Password", intent_ref: $valid_define.property } after valid_define
      fixture synthesize_with_lang { target_symbol: "clef/concept/User", intent_ref: $valid_define.property, formal_language: "lean" } after valid_define
    }

    action coverage(target_symbol: String) {
      -> ok(total: Int, proved: Int, refuted: Int, unproven: Int, coverage_pct: Float) {
        Proof coverage statistics for target.
      }

      fixture valid_coverage { target_symbol: "clef/concept/Password" } after valid_define
      fixture coverage_unknown { target_symbol: "clef/concept/Unknown" } after valid_define
    }

    action list(target_symbol: option String, kind: option String, status: option String) {
      -> ok(count: Int, items: String) {
        Filtered listing. All params optional.
      }

      fixture list_all { } after valid_define
      fixture list_by_kind { kind: "invariant" } after valid_define
    }

    action invalidate(id: String) {
      -> ok(id: String, previous_status: String, status: String) {
        Resets proved/refuted property to "unproven" when source changes.
        Triggered by Score change detection via sync.
      }
      -> notfound(id: String) {
        Property does not exist.
      }

      fixture valid_invalidate { id: $valid_define.property } after valid_define
      fixture invalidate_missing { id: "nonexistent" } -> notfound
    }
  }

  example "define-then-coverage": {

    after define(target_symbol: "clef/concept/Password", kind: "invariant", property_text: "forall p: Password | len(p.hash) > 0", formal_language: "smtlib", scope: "local", priority: "required")

          -> ok(property: p)

        then check(property: p, solver: "z3", timeout_ms: 5000)

          -> ok(property: p, status: "proved")

        and  coverage(target_symbol: "clef/concept/Password")

          -> ok(total: 1, proved: 1, refuted: 0, unknown: 0, timeout: 0, coverage_pct: 100.0)

  }


  always "valid-target_symbol" {

    forall p in properties:

      p.target_symbol != none

  }

  never "orphaned-kind" {

    exists p in properties:

      p.kind = none

  }

  action define {

    requires: target_symbol != ""

    ensures ok: target_symbol != none

  }
}
