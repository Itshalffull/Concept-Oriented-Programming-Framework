@version(1)
@category("testing")
concept EffectContractRenderer [R] {

  purpose {
    Render a HandlerDescriptor into a vitest test source string that
    asserts the handler performs EXACTLY the declared storage reads/
    writes and transport effects. The emitted test invokes the
    handler with a fixture input under spy storage + transport
    adapters, collects observed effects, and fails if the handler
    adds an undeclared effect or drops a declared one. Self-registers
    via PluginRegistry.
  }

  state {
    renderers: set R

    identity {
      name: R -> String
    }

    metadata {
      capabilities: R -> String
    }
  }

  actions {

    action register() {
      -> ok(name: String, capabilities: String) {
        Return static metadata for PluginRegistry. The renderer
        identifies itself as "effect-contract" and declares
        capabilities: storage-spy, transport-spy, exact-match,
        undeclared-effect-detection, dropped-effect-detection.
      }

      fixture register_ok {}
    }

    action render(descriptor: String) {
      -> ok(code: String) {
        Translate the JSON-encoded HandlerDescriptor into a vitest
        test source string asserting the effect contract.
      }
      -> error(message: String) {
        The descriptor string is not valid JSON or missing required
        fields.
      }

      fixture render_ok {
        descriptor: "{\"conceptName\":\"User\",\"actionName\":\"create\",\"kind\":\"storage\",\"reads\":[\"users\"],\"writes\":[\"users\"],\"performs\":[],\"variants\":[\"ok\",\"duplicate\"]}"
      }
      fixture render_bad_json {
        descriptor: "not valid json"
      } -> error
      fixture render_empty {
        descriptor: ""
      } -> error
    }
  }

  example "register then render": {
    after register() -> ok(name: n, capabilities: caps)
    then render(descriptor: "{\"conceptName\":\"X\",\"actionName\":\"a\",\"kind\":\"storage\",\"reads\":[],\"writes\":[],\"performs\":[],\"variants\":[\"ok\"]}") -> ok(code: c)
  }

  never "register issued without name": {
    exists r in renderers: r.name = ""
  }

  always "registered renderers carry capabilities": {
    forall r in renderers: r.capabilities != ""
  }
}
