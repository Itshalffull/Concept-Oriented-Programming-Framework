# Wire VueRenderer/register into PluginRegistry so the rendering
# dispatch layer can discover and invoke the Vue backend by name.

sync RegisterVueRenderer [eager]
  purpose { Wire VueRenderer/register into PluginRegistry. }
when {
  VueRenderer/register: []
    => ok(name: ?name; capabilities: ?caps)
}
then {
  PluginRegistry/register: [
    type: "test-plan-renderer";
    name: ?name;
    metadata: { capabilities: ?caps }
  ]
}
