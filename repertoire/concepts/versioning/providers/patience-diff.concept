# @fixtures-added
@version(2)
concept PatienceDiff [C] {

  purpose {
    Compute diffs using the Patience diff algorithm. Produces more
    human-readable diffs by aligning unique lines first. Better than
    Myers for refactored or moved code blocks.
  }

  state {
    cache: set C
  }

  actions {
    action register() {
      -> ok(name: String, category: String, contentTypes: list String) {
        Returns provider metadata for PluginRegistry registration.
        name: "patience", category: "diff",
        contentTypes: ["text/plain", "text/*"]
      }

      fixture valid {}
    }

    action compute(contentA: Bytes, contentB: Bytes) {
      -> ok(editScript: Bytes, distance: Int) {
        Patience edit script and edit distance.
      }
      -> unsupportedContent(message: String) {
        Content type not supported by this provider.
      }

      fixture diff_text { contentA: "import os\ndef main():\n  pass", contentB: "import os\nimport sys\ndef main():\n  pass" }
      fixture non_string { contentA: 123, contentB: "text" } -> error
    }
  }

  example "compute then compute": {
    after compute(contentA: a, contentB: a) -> ok(editScript: _, distance: 0)
    then compute(contentA: a, contentB: b) -> ok(editScript: es, distance: d)
  }
}
