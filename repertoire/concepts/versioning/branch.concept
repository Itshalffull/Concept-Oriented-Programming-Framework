# @fixtures-added
@version(2)
concept Branch [B] {

  purpose {
    Named parallel lines of development with lifecycle management.
    Branches are mutable pointers over immutable DAG history —
    advancing the head, protecting against direct writes, and
    tracking upstream relationships.
  }

  state {
    branches: set B;
    name: B -> String;
    head: B -> String;
    protected: B -> Bool;
    upstream: B -> option B;
    created: B -> String;
    archived: set B
  }

  actions {
    action create(name: String, fromNode: String) {
      -> ok(branch: B) {
        Branch created with head pointing at fromNode.
      }
      -> exists(message: String) {
        Branch name already in use.
      }
      -> unknownNode(message: String) {
        fromNode not found in DAGHistory.
      }

      fixture create_feature { name: "feature/auth", fromNode: "dag-history-1" }
      fixture empty_branch_name { name: "", fromNode: "dag-history-1" }
    }

    action advance(branch: B, newNode: String) {
      -> ok() {
        Branch head moved forward to newNode.
      }
      -> notFound(message: String) {
        Branch not found.
      }
      -> protected(message: String) {
        Branch is protected. Direct advance rejected.
      }
      -> unknownNode(message: String) {
        newNode not found in DAGHistory.
      }

      fixture advance_head { branch: "branch-1", newNode: "dag-history-2" }
      fixture advance_empty_node { branch: "branch-1", newNode: "" } -> error
    }

    action delete(branch: B) {
      -> ok() {
        Branch removed.
      }
      -> notFound(message: String) {
        Branch not found.
      }
      -> protected(message: String) {
        Protected branch cannot be deleted.
      }

      fixture delete_existing { branch: "branch-1" }
      fixture delete_missing { branch: "branch-nonexistent" } -> error
    }

    action protect(branch: B) {
      -> ok() {
        Branch marked as protected.
      }
      -> notFound(message: String) {
        Branch not found.
      }

      fixture protect_main { branch: "branch-1" }
      fixture protect_missing { branch: "branch-nonexistent" } -> error
    }

    action setUpstream(branch: B, upstream: B) {
      -> ok() {
        Upstream tracking branch set.
      }
      -> notFound(message: String) {
        Branch or upstream not found.
      }

      fixture set_upstream_main { branch: "branch-2", upstream: "branch-1" }
      fixture upstream_missing { branch: "branch-2", upstream: "branch-nonexistent" } -> error
    }

    action divergencePoint(b1: B, b2: B) {
      -> ok(nodeId: String) {
        Returns the DAGHistory node where the two branches diverged.
      }
      -> noDivergence(message: String) {
        One is a direct ancestor of the other. No divergence point.
      }
      -> notFound(message: String) {
        b1 or b2 not found.
      }

      fixture find_divergence { b1: "branch-1", b2: "branch-2" }
      fixture divergence_missing { b1: "branch-nonexistent", b2: "branch-1" } -> error
    }

    action archive(branch: B) {
      -> ok() {
        Branch archived. Remains queryable but excluded from active listings.
      }
      -> notFound(message: String) {
        Branch not found.
      }

      fixture archive_old { branch: "branch-1" }
      fixture archive_missing { branch: "branch-nonexistent" } -> error
    }
  }

  example "create then advance": {
    after create(name: n, fromNode: f) -> ok(branch: b)
    then advance(branch: b, newNode: n2) -> ok()
  }

  example "protect then advance": {
    after protect(branch: b) -> ok()
    then advance(branch: b, newNode: _) -> protected(message: _)
  }


  always "branches have required fields": {
    forall b in branches:
    b.name != none
  }

  never "orphaned entry in branches": {
    exists b in branches:
    b.name = none
  }

  action create {
    requires: name != ""
    ensures ok: name != none
  }

  action advance {
    requires: newNode != ""
    ensures ok: branch != none
  }

  action delete {
    ensures ok: branch != none
  }
}
