@version(2)
@gate
concept StepRun [S] {

  purpose {
    Track per-step execution state within a process run, including
    step type dispatch, attempt counting, and input/output capture.
  }

  state {
    steps: set S
    run_ref: S -> String
    step_key: S -> String
    step_type: S -> String                // human | automation | llm | approval | manual | subprocess | webhook_wait
    status: S -> String                   // pending | ready | active | completed | failed | cancelled | skipped
    attempt: S -> Int
    input: S -> option Bytes
    output: S -> option Bytes
    error: S -> option String
    started_at: S -> option DateTime
    ended_at: S -> option DateTime
  }

  capabilities {
    requires persistent-storage
  }

  actions {
    action start(run_ref: String, step_key: String, step_type: String, input: Bytes) {
      -> ok(step: S, run_ref: String, step_key: String, step_type: String) {
        Creates a step run in active status. Records start timestamp.
        Increments attempt counter if a step with same run_ref+step_key already
        exists in failed status (retry scenario).
      }
      -> ok(step: S) {
        A step run for this run_ref+step_key is already active.
      }
    }

    action complete(step: S, output: Bytes) {
      -> ok(step: S, run_ref: String, step_key: String, output: Bytes) {
        Transitions step from active to completed. Records end timestamp and output.
      }
      -> ok(step: S) {
        Step is not in active status.
      }
    }

    action fail(step: S, error: String) {
      -> error(step: S, run_ref: String, step_key: String, message: String) {
        Transitions step from active to failed. Records end timestamp and error.
      }
      -> ok(step: S) {
        Step is not in active status.
      }
    }

    action cancel(step: S) {
      -> ok(step: S) {
        Transitions step from active or pending to cancelled.
      }
      -> ok(step: S) {
        Step is in a terminal status.
      }
    }

    action skip(step: S) {
      -> ok(step: S) {
        Transitions step from pending to skipped. Used when conditional
        routing determines this step should not execute.
      }
      -> ok(step: S) {
        Step is not in pending status.
      }
    }

    action get(step: S) {
      -> ok(step: S, run_ref: String, step_key: String, status: String, attempt: Int) {
        Returns step state.
      }
      -> not_found(step: S) {
        No step run with this identifier exists.
      }
    }

    action seed(run_ref: String, step_key: String, step_type: String, input: Bytes, output: Bytes) {
      -> ok(step: S) {
        Pre-populates a completed StepRun record for replay purposes. The run must
        be in draft or starting status; the step is recorded as completed with the
        provided input and output so selective redrive can resume after this step.
      }
      -> duplicate(step: S) {
        A StepRun with this run_ref+step_key already exists. Returns the existing
        step without overwriting it.
      }
      -> parent_run_active(message: String) {
        The parent ProcessRun is already executing (status is active, completed,
        failed, or cancelled). Pre-seeding is only allowed while the run is in
        draft or starting status.
      }
      -> error(message: String) {
        run_ref or step_key is empty, or a storage error occurred.
      }
      fixture seed_ok { run_ref: "run-42", step_key: "fetch-user", step_type: "automation", input: "eyJpZCI6IjEifQ==", output: "eyJ1c2VyIjoiYWxpY2UifQ==" }
      fixture seed_duplicate { run_ref: "run-42", step_key: "fetch-user", step_type: "automation", input: "eyJpZCI6IjEifQ==", output: "eyJ1c2VyIjoiYWxpY2UifQ==" } -> duplicate
      fixture seed_empty_run_ref { run_ref: "", step_key: "fetch-user", step_type: "automation", input: "e30=", output: "e30=" } -> error
    }

    action getIO(step: S) {
      -> ok(input: Bytes, output: Bytes, status: String) {
        Returns the raw input and output payloads for the step along with its
        current status. Kept separate from get so permission gates
        (StepIOVisibility) can attach exclusively to this action.
      }
      -> notfound(message: String) {
        No step run with this identifier exists.
      }
      -> error(message: String) {
        A storage error occurred retrieving the step record.
      }
      fixture getio_ok { step: $seed_ok.step } after seed_ok
      fixture getio_missing { step: "nonexistent-step" } -> notfound
    }
  }

  example "start then complete": {
    after start(run_ref: "r1", step_key: "kyc", step_type: "automation", input: d) -> ok(step: s, run_ref: "r1", step_key: "kyc", step_type: "automation")
    then complete(step: s, output: o) -> ok(step: s, run_ref: "r1", step_key: "kyc", output: o)
  }


  always "steps have required fields": {
    forall s in steps:
    s.run_ref != none
  }

  never "orphaned entry in steps": {
    exists s in steps:
    s.run_ref = none
  }

  action start {
    requires: run_ref != ""
    ensures ok: run_ref != none
  }

  action complete {
    ensures ok: step != none
  }

  action fail {
    requires: error != ""
    ensures ok: step != none
  }
}
