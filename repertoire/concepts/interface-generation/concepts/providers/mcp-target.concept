# @fixtures-added
@version(3)
concept McpTarget [M] {

  purpose {
    Generate MCP (Model Context Protocol) server implementations
    from concept projections. Owns tool/resource/template
    classification, input schema derivation, description
    generation for LLM comprehension, transport setup
    (stdio, SSE, HTTP), hierarchical tool grouping, and tool
    catalog generation for lazy loading. Generates both full
    .tools.ts files and .catalog.json files with brief
    descriptions for on-demand tool discovery.
    See Architecture doc Section 2.5.
  }

  state {
    tools: set M
    config {
      serverName: M -> String
      transport: M -> String
      version: M -> String
    }
    mapping {
      concept: M -> String
      action: M -> String
      mcpType: M -> String
      toolName: M -> String
      description: M -> String
    }
    hierarchical {
      parentPath: M -> option String
      childrenTool: M -> option String
      ancestorsTool: M -> option String
    }
    content: M -> String
  }

  actions {
    action generate(projection: String, config: String) {
      -> ok(tools: list String, files: list String) {
        MCP server implementation generated from projection.
        Actions classified as tools, resources, or templates
        based on action semantics and annotations. Input
        schemas derived from action parameters. Descriptions
        optimized for LLM comprehension. When @hierarchical
        trait is detected, resource URIs encode parent path
        (e.g. "concept://root/sub1/sub2") and list_children
        / get_ancestors tools are generated.
      }
      -> ok(count: Int, limit: Int) {
        Generated tool count exceeds the configured limit.
        Consider grouping related actions or using resource
        types to reduce tool count.
      }

      fixture generate_agent { projection: "agent-projection", config: "{\"serverName\":\"agent-mcp\",\"transport\":\"stdio\"}" }
      fixture generate_default_config { projection: "score-projection", config: "{}" }
      fixture generate_empty_projection { projection: "", config: "{}" } -> error
    }

    action validate(tool: M) {
      -> ok(tool: M) {
        MCP server schema is valid. Tool input schemas match
        action parameter types. Descriptions are present and
        within length limits. Transport configuration is
        consistent. Hierarchical resource URIs are well-formed.
      }
      -> ok(tool: M, toolName: String) {
        Tool lacks a description. MCP tools require
        descriptions for LLM discoverability.
      }

      fixture validate_existing { tool: "mcp-agent-001" }
      fixture validate_unknown { tool: "mcp-nonexistent" } -> error
    }

    action listTools(concept: String) {
      -> ok(tools: list String, resources: list String, templates: list String) {
        Return all generated MCP primitives for a concept
        grouped by MCP type, including hierarchy tools.
      }

      fixture list_tools_agent { concept: "Agent" } after generate_agent
      fixture list_tools_score { concept: "ScoreApi" } after generate_agent
      fixture list_tools_empty { concept: "" } -> error
    }
  }

  example "generate-then-listTools": {

    after generate(projection: "agent-projection", config: "{}") -> ok(tools: t, files: f)

        then listTools(concept: "Agent") -> ok(tools: tl, resources: r, templates: tp)

  }


  always "valid-serverName" {

    forall m in tools:

      m.serverName != none

  }

  never "orphaned-transport" {

    exists m in tools:

      m.transport = none

  }

  action generate {

    requires: projection != ""

    ensures ok: projection != none

  }
}
