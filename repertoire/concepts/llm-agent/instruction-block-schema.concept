# @fixtures-added
@version(1)
concept InstructionBlockSchema [B] {

  purpose {
    Define the schema for instruction blocks — the children of an agent
    persona page. Each instruction block is a ContentNode block with a
    section_type (system, persona, domain, behavioral, format, tools,
    custom), role (system, user, assistant), priority for truncation
    ordering, required flag, and max_tokens allocation. This concept
    manages block schema registration, validation, and section type
    enumeration. The actual block content lives in ContentNode; this
    concept defines what makes a ContentNode block an instruction block.
  }

  state {
    blockSchemas: set B
    sectionType: B -> String
    role: B -> String
    priority: B -> Int
    required: B -> Bool
    maxTokens: B -> Int
    description: B -> String
  }

  capabilities {
    requires persistent-storage
  }

  actions {
    action register(block: B, sectionType: String, role: String,
                    priority: Int, required: Bool, maxTokens: Int,
                    description: String) {
      -> ok(block: B) {
        Registers an instruction block schema definition. Valid
        sectionTypes: system, persona, domain, behavioral, format,
        tools, custom. Valid roles: system, user, assistant. Priority
        ranges 0-100 where higher means more important for truncation.
      }
      -> duplicate(message: String) {
        Block schema with this identifier already exists.
      }
      -> invalid(message: String) {
        Invalid sectionType or role, or empty block identifier.
      }

      fixture register_system_block { block: "system-instructions", sectionType: "system", role: "system", priority: 100, required: true, maxTokens: 2000, description: "Core system instructions" }
      fixture register_persona_block { block: "personality", sectionType: "persona", role: "system", priority: 90, required: false, maxTokens: 1000, description: "Agent personality and communication style" }
      fixture register_empty { block: "", sectionType: "system", role: "system", priority: 100, required: true, maxTokens: 2000, description: "Test" } -> error
      fixture register_invalid_type { block: "bad-block", sectionType: "invalid_type", role: "system", priority: 100, required: true, maxTokens: 2000, description: "Test" } -> invalid
    }

    action validate(block: B, nodeId: String) {
      -> ok(valid: Bool, errors: String) {
        Validates a ContentNode block meets the instruction block schema.
        Checks that the block has content and that its properties match
        the schema definition. Returns validation errors as JSON array.
      }
      -> notfound(message: String) {
        Block schema not found.
      }

      fixture validate_block { block: $register_system_block.block, nodeId: "block-node-1" } after register_system_block
      fixture validate_missing { block: "nonexistent", nodeId: "node-1" } -> notfound
    }

    action listSectionTypes() {
      -> ok(types: String) {
        Returns all registered section types as JSON array with their
        default priority, role, and required settings.
      }

      fixture list_types { } after register_system_block
    }

    action getBlockDefaults(sectionType: String) {
      -> ok(defaults: String) {
        Returns default property values for a given section type as JSON,
        including role, priority, required, maxTokens, and description.
      }
      -> notfound(message: String) {
        No block registered with this section type.
      }

      fixture get_system_defaults { sectionType: "system" } after register_system_block
      fixture get_unknown_defaults { sectionType: "unknown_type" } -> notfound
    }

    action updatePriority(block: B, priority: Int) {
      -> ok(block: B) {
        Updates the priority of a block schema. Priority must be 0-100.
      }
      -> notfound(message: String) {
        Block schema not found.
      }
      -> invalid(message: String) {
        Priority out of valid range (0-100).
      }

      fixture update_priority { block: $register_system_block.block, priority: 95 } after register_system_block
      fixture update_missing_priority { block: "nonexistent", priority: 50 } -> notfound
    }
  }

  example "register-then-validate": {

    after register(block: b, sectionType: "system", role: "system",
                       priority: 100, required: true, maxTokens: 2000,
                       description: "Core instructions")
          -> ok(block: b)

        then validate(block: b, nodeId: "node-1")
          -> ok(valid: true, errors: "[]")

  }


  always "valid-sectionType" {

    forall b in blockSchemas:

      b.sectionType != none

  }

  never "orphaned-role" {

    exists b in blockSchemas:

      b.role = none

  }

  action register {

    requires: block != ""

    ensures ok: block != none

  }
}
