# Route Runtime/provision to VercelRuntime for Vercel runtimes

sync RouteToVercel [eager]
  purpose: "Route provisioning actions to the Vercel provider when the runtime type is vercel"
when {
  Runtime/provision: [ concept: ?concept; runtimeType: "vercel"; framework: ?framework; config: ?config ]
    => [ instance: ?instance; endpoint: ?endpoint ]
}
then {
  VercelRuntime/provision: [ concept: ?concept; framework: ?framework ]
}
