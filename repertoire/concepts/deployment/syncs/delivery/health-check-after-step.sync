# Health check after rollout advance — Architecture doc Section 2.3
# Each rollout step triggers a suite-level health check.

sync HealthCheckAfterStep [eager]
when {
  Rollout/advance: [ rollout: ?r ]
    => [ rollout: ?r; newWeight: ?w; step: ?step ]
}
then {
  Health/checkKit: [ suite: ?suite; environment: ?env ]
}
