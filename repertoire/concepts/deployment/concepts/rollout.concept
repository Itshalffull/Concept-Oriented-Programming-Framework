# @fixtures-added
@version(1)
concept Rollout [R] {

  purpose {
    Manage progressive delivery of concept deployments.
    Controls traffic splitting between old and new versions,
    monitors health between steps, and triggers rollback on
    failure. Strategies: canary, blue-green, rolling.
  }

  state {
    rollouts: set R
    config {
      strategy: R -> String
      steps: R -> list { weight: Int, pauseSeconds: Int }
      successCriteria: R -> { maxErrorRate: Float, maxLatencyP99: Int }
      autoRollback: R -> Bool
    }
    progress {
      currentStep: R -> Int
      currentWeight: R -> Int
      startedAt: R -> DateTime
      status: R -> String
    }
    versions {
      oldVersion: R -> String
      newVersion: R -> String
      plan: R -> String
    }
  }

  actions {
    action begin(plan: String, strategy: String, steps: list String) {
      -> ok(rollout: R) {
        Initialize progressive rollout. First step begins
        with minimal traffic weight.
      }
      -> ok(message: String) {
        Unknown strategy or malformed step configuration.
      }

      fixture canary_rollout { plan: "dp-042", strategy: "canary", steps: ["step1", "step2"] }
      fixture blue_green_rollout { plan: "dp-100", strategy: "blue-green", steps: ["swap"] }
      fixture invalid_strategy { plan: "dp-001", strategy: "rainbow", steps: ["step1"] } -> invalidStrategy
    }

    action advance(rollout: R) {
      -> ok(rollout: R, newWeight: Int, step: Int) {
        Move to next traffic weight step.
      }
      -> ok(rollout: R) {
        All steps completed. New version receives full traffic.
      }
      -> ok(rollout: R, reason: String) {
        Rollout paused due to analysis results. Waiting for
        manual intervention or auto-resume timer.
      }

      fixture advance_active { rollout: $canary_rollout.rollout } after canary_rollout
      fixture advance_missing { rollout: "ro-nonexistent" } -> paused
    }

    action pause(rollout: R, reason: String) {
      -> ok(rollout: R) {
        Freeze at current traffic weight.
      }

      fixture pause_active { rollout: $canary_rollout.rollout, reason: "High error rate detected" } after canary_rollout
      fixture pause_missing { rollout: "ro-nonexistent", reason: "Manual pause" } after canary_rollout
    }

    action resume(rollout: R) {
      -> ok(rollout: R, currentWeight: Int) {
        Continue from pause.
      }

      fixture resume_paused { rollout: $canary_rollout.rollout } after canary_rollout
      fixture resume_missing { rollout: "ro-nonexistent" } after canary_rollout
    }

    action abort(rollout: R) {
      -> ok(rollout: R) {
        Immediately shift all traffic back to old version.
        Triggers compensating deploy actions.
      }
      -> ok(rollout: R) {
        Rollout already finished.
      }

      fixture abort_active { rollout: $canary_rollout.rollout } after canary_rollout
      fixture abort_completed { rollout: "ro-completed-001" } -> alreadyComplete
    }

    action status(rollout: R) {
      -> ok(rollout: R, step: Int, weight: Int, status: String, elapsed: Int) {
        Current state of the rollout.
      }

      fixture status_existing { rollout: $canary_rollout.rollout } after canary_rollout
      fixture status_unknown { rollout: "ro-nonexistent" } after canary_rollout
    }
  }

  example "begin-then-advance": {

    after begin(plan: "dp-001", strategy: "canary", steps: s) -> ok(rollout: r)

        then advance(rollout: r) -> ok(rollout: r, newWeight: 25, step: 2)

  }


  always "valid-strategy" {

    forall r in rollouts:

      r.strategy != none

  }

  never "orphaned-strategy" {

    exists r in rollouts:

      r.strategy = none

  }

  action begin {

    requires: plan != ""

    ensures ok: plan != none

  }
}
