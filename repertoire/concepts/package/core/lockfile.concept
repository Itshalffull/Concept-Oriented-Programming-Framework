# @fixtures-added
@version(2)
concept Lockfile [L] {

  purpose {
    Serialized resolved dependency graph. Captures the exact module versions,
    content hashes, artifact URLs, and enabled features from a successful
    resolution, ensuring deterministic and reproducible installations across
    environments. Supports integrity verification and diffing between versions.
  }

  state {
    lockfiles: set L
    project_hash: L -> String
    entries: L -> list {
      module_id: String,
      version: String,
      content_hash: String,
      artifact_url: String,
      integrity: String,
      features_enabled: list String,
      dependencies: list String
    }
    metadata: L -> {
      resolver_version: String,
      resolved_at: String,
      registry_snapshot: String
    }
  }

  actions {
    action write(project_hash: String,
                 entries: list {module_id: String, version: String,
                               content_hash: String, artifact_url: String,
                               integrity: String, features_enabled: list String,
                               dependencies: list String},
                 metadata: {resolver_version: String, resolved_at: String,
                            registry_snapshot: String}) {
      -> ok(lockfile: L) {
        Serializes the resolved dependency graph into a lockfile. Computes
        the project_hash from the manifest contents to detect when the
        lockfile is stale. Each entry records the exact resolved version,
        content hash for verification, artifact download URL, integrity
        digest, enabled features, and direct dependency list.
      }
      -> error(message: String) {
        Serialization failed (e.g., entries contain circular references
        or invalid content hashes).
      }

      fixture write_valid_lockfile { project_hash: "sha256:manifest-hash-001", entries: [{"module_id": "lodash", "version": "4.17.21", "content_hash": "sha256:abc123", "artifact_url": "https://registry.example.com/lodash.tgz", "integrity": "sha256:abc123", "features_enabled": [], "dependencies": []}], metadata: {"resolver_version": "1.0.0", "resolved_at": "2026-01-15T10:00:00Z", "registry_snapshot": "snap-001"} }
      fixture write_circular_ref { project_hash: "sha256:hash", entries: [{"module_id": "self-ref", "version": "1.0.0", "content_hash": "sha256:abc", "artifact_url": "url", "integrity": "sha256:abc", "features_enabled": [], "dependencies": ["self-ref"]}], metadata: {"resolver_version": "1.0.0", "resolved_at": "2026-01-15T10:00:00Z", "registry_snapshot": "snap-001"} } -> error
    }

    action read(lockfile: L) {
      -> ok(project_hash: String,
            entries: list {module_id: String, version: String,
                          content_hash: String, artifact_url: String,
                          integrity: String, features_enabled: list String,
                          dependencies: list String},
            metadata: {resolver_version: String, resolved_at: String,
                       registry_snapshot: String}) {
        Deserializes and returns the full lockfile contents including
        project hash, all entries, and resolver metadata.
      }
      -> notfound() {
        The lockfile does not exist or cannot be read.
      }
      -> corrupt(message: String) {
        The lockfile exists but cannot be parsed or has been tampered with.
      }

      fixture read_existing_lockfile { lockfile: $write_valid_lockfile.lockfile } after write_valid_lockfile
      fixture read_nonexistent_lockfile { lockfile: "lock-nonexistent" } -> error
    }

    action verify(lockfile: L) {
      -> ok() {
        Verifies integrity of all lockfile entries by checking content
        hashes and integrity digests against the actual artifacts. Confirms
        the project_hash still matches the current manifest.
      }
      -> stale(reason: String) {
        The project_hash no longer matches the current manifest, indicating
        the lockfile needs to be regenerated.
      }
      -> tampered(entries: list String) {
        One or more entries have content hashes or integrity digests that
        do not match the downloaded artifacts.
      }

      fixture verify_valid_lockfile { lockfile: $write_valid_lockfile.lockfile } after write_valid_lockfile
      fixture verify_nonexistent_lockfile { lockfile: "lock-nonexistent" } -> error
    }

    action diff(old_lockfile: L, new_lockfile: L) {
      -> ok(added: list String, removed: list String,
            updated: list {module_id: String, old_version: String,
                           new_version: String}) {
        Compares two lockfiles and returns the differences: newly added
        modules, removed modules, and version-changed modules.
      }
      -> error(message: String) {
        One or both lockfiles could not be read.
      }

      fixture diff_two_lockfiles { old_lockfile: "lock-1", new_lockfile: "lock-2" }
      fixture diff_missing_lockfile { old_lockfile: "lock-nonexistent", new_lockfile: "lock-1" } -> error
    }
  }

  example "write then read": {
    after write(project_hash: "hash1", entries: es, metadata: m)
      -> ok(lockfile: lf)
    then read(lockfile: lf)
      -> ok(project_hash: "hash1", entries: es, metadata: m)
  }

  example "write then verify": {
    after write(project_hash: "hash1", entries: es, metadata: m)
      -> ok(lockfile: lf)
    then verify(lockfile: lf) -> ok()
  }


  always "lockfiles have required fields": {
    forall l in lockfiles:
    l.project_hash != none
  }

  never "orphaned entry in lockfiles": {
    exists l in lockfiles:
    l.project_hash = none
  }

  action write {
    requires: project_hash != ""
    ensures ok: project_hash != none
  }

  action read {
    ensures ok: lockfile != none
  }

  action verify {
    ensures ok: lockfile != none
  }
}
