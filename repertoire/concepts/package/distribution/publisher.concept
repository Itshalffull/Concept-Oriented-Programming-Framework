# @fixtures-added
@version(2)
concept Publisher [U] {

  purpose {
    Package and upload modules to a registry. Manages the full publication
    lifecycle: artifact packaging, cryptographic signing, provenance
    attestation, SBOM generation, and registry upload.
  }

  state {
    publications: set U
    module_id: U -> String
    version: U -> String
    artifact_hash: U -> String
    signature: U -> option String
    provenance: U -> option {
      builder: String,
      source_repo: String,
      source_commit: String,
      build_timestamp: String,
      slsa_level: Int
    }
    sbom: U -> option String
    status: U -> String
  }

  actions {
    action package(source_path: String, kind: String,
                   manifest: {module_id: String, version: String,
                              dependencies: list String}) {
      -> ok(publication: U) {
        Bundles the source at source_path into a distributable artifact.
        Computes artifact_hash. Sets status to "packaging" then advances
        to next stage. Validates manifest completeness.
      }
      -> invalid(errors: list String) {
        Source path missing, manifest incomplete, or kind unsupported.
      }

      fixture package_library { source_path: "/src/auth", kind: "library", manifest: {"module_id": "auth", "version": "2.0.0", "dependencies": ["crypto"]} }
      fixture package_invalid_kind { source_path: "/src/auth", kind: "unknown-kind", manifest: {"module_id": "auth", "version": "1.0.0", "dependencies": []} } -> error
    }

    action sign(publication: U) {
      -> ok() {
        Cryptographically signs the artifact. Stores the signature.
        Advances status to "signing" then to the next stage.
      }
      -> error(message: String) {
        Signing key unavailable or signing process failed.
      }

      fixture sign_existing { publication: $package_library.publication } after package_library
      fixture sign_missing { publication: "pub-nonexistent" } -> error
    }

    action attest(publication: U, builder: String,
                  source_repo: String, source_commit: String) {
      -> ok() {
        Records provenance metadata: builder identity, source repository,
        commit hash, build timestamp, and computed SLSA level.
      }

      fixture attest_ci_build { publication: $package_library.publication, builder: "github-actions", source_repo: "https://github.com/org/repo", source_commit: "abc123def456" } after package_library
      fixture attest_missing_pub { publication: "pub-nonexistent", builder: "ci", source_repo: "repo", source_commit: "000" } -> error
    }

    action generateSbom(publication: U) {
      -> ok() {
        Generates a Software Bill of Materials for the packaged artifact.
        Stores the SBOM in a standard format (SPDX or CycloneDX).
      }

      fixture generate_sbom_existing { publication: $package_library.publication } after package_library
      fixture generate_sbom_missing { publication: "pub-nonexistent" } -> error
    }

    action upload(publication: U, registry_url: String) {
      -> ok() {
        Uploads the artifact, signature, provenance, and SBOM to the
        registry. Advances status to "uploading" then "published".
      }
      -> duplicate(existing_version: String) {
        A publication with the same module_id and version already exists.
      }
      -> unauthorized(message: String) {
        Authentication or authorization failed for the registry.
      }
      -> error(message: String) {
        Network or server error during upload.
      }

      fixture upload_to_registry { publication: $package_library.publication, registry_url: "https://registry.example.com/api/v1" } after package_library
      fixture upload_missing_pub { publication: "pub-nonexistent", registry_url: "https://registry.example.com/api/v1" } -> error
    }
  }

  example "package then sign": {
    after package(source_path: src, kind: "library",
                  manifest: m) -> ok(publication: u)
    then sign(publication: u) -> ok()
    then upload(publication: u, registry_url: reg) -> ok()
    and u.status = "published"
  }

  example "package then attest": {
    after package(source_path: src, kind: "library",
                  manifest: m) -> ok(publication: u)
    then attest(publication: u, builder: "ci",
                source_repo: "repo", source_commit: "abc123") -> ok()
    and u.provenance != none
  }


  always "publications have required fields": {
    forall u in publications:
    u.module_id != none
  }

  never "orphaned entry in publications": {
    exists u in publications:
    u.module_id = none
  }

  action package {
    requires: source_path != ""
    ensures ok: source_path != none
  }

  action sign {
    ensures ok: publication != none
  }

  action attest {
    requires: builder != ""
    ensures ok: publication != none
  }
}
