# Register LLMAutomationProvider with PluginRegistry as an automation provider

sync RegisterLLMProvider [eager]
when {
  LLMAutomationProvider/register: []
    => [ provider_name: ?name ]
}
then {
  PluginRegistry/register: [
    type: "automation-provider";
    name: ?name;
    metadata: {
      name: ?name;
      concept: "LLMAutomationProvider";
      action: "execute";
      category: "automation-provider"
    }
  ]
}
