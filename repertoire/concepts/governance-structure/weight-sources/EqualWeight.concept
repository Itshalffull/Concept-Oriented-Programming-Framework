# @fixtures-added
@version(1)
concept EqualWeight [EW] {

  purpose {
    Assign identical governance weight to every eligible participant
    regardless of holdings, reputation, or stake — one person, one vote.
  }

  state {
    configurations: set EW
    weightPerPerson: EW -> Float
  }

  actions {
    action configure(weightPerPerson: option Float) {
      -> configured(config: EW) {
        Every participant receives the given weight. Default 1.0.
      }

      fixture configure_default { weightPerPerson: 1.0 }
      fixture configure_custom { weightPerPerson: 5.0 }
    }

    action getWeight(config: EW, participant: String) {
      -> weight(participant: String, weight: Float) {
        Returns the fixed weight value.
      }

      fixture get_alice { config: "ew-cfg-001", participant: "alice" } after configure_default
      fixture get_empty_participant { config: "ew-cfg-001", participant: "" } -> error
    }
  }

  example "configure-then-getWeight": {

    after configure(weightPerPerson: 1.0) -> configured(config: ew)

        then getWeight(config: ew, participant: _) -> weight(participant: _, weight: 1.0)

  }


  always "valid-weightPerPerson" {

    forall ew in configurations:

      ew.weightPerPerson != none

  }

  never "orphaned-weightPerPerson" {

    exists ew in configurations:

      ew.weightPerPerson = none

  }

  action configure {

    requires: weightPerPerson != ""

    ensures configured: weightPerPerson != none

  }
}
