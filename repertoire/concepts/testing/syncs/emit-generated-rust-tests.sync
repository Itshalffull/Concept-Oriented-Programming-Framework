# Route generated Rust test files through Emitter

sync EmitGeneratedRustTests [eager]
  purpose: "Route rendered Rust test code from TestGenRust through Emitter for content-addressed file writes with provenance tracking"
when {
  TestGenRust/render: [ test_plan: ?plan; output_path: ?path ]
    => ok(result: ?result; rendered_code: ?code; file_path: ?filePath; test_count: ?count)
}
then {
  Emitter/write: [
    path: ?filePath;
    content: ?code;
    sources: ?plan;
    generator: "TestGenRust"
  ]
}
