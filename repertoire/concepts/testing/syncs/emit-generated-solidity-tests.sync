# Route generated Solidity test files through Emitter

sync EmitGeneratedSolidityTests [eager]
  purpose: "Route rendered Solidity test code from TestGenSolidity through Emitter for content-addressed file writes with provenance tracking"
when {
  TestGenSolidity/render: [ test_plan: ?plan; output_path: ?path ]
    => ok(result: ?result; rendered_code: ?code; file_path: ?filePath; test_count: ?count)
}
then {
  Emitter/write: [
    path: ?filePath;
    content: ?code;
    sources: ?plan;
    generator: "TestGenSolidity"
  ]
}
