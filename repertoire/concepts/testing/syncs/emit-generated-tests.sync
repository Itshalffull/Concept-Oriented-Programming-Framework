# Route generated test files through Emitter for content-addressed writes

sync EmitGeneratedTests [eager]
  purpose: "Route rendered test code from TestGen providers through Emitter for content-addressed file writes with provenance tracking"
when {
  TestGenTypeScript/render: [ test_plan: ?plan; output_path: ?path ]
    => ok(result: ?result; rendered_code: ?code; file_path: ?filePath; test_count: ?count)
}
then {
  Emitter/write: [
    path: ?filePath;
    content: ?code;
    sources: ?plan;
    generator: "TestGenTypeScript"
  ]
}
