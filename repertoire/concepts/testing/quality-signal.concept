# @fixtures-added
@version(2)
concept QualitySignal [Q] {

  purpose {
    Normalize quality outcomes from testing, formal verification,
    and other quality producers into a single stream consumable
    by Score rollups and deploy gates. Coordination-only: does
    not run tests or proofs, only stores normalized outcomes.
  }

  state {
    signals: set Q
    record {
      target_symbol: Q -> String
      dimension: Q -> String
      status: Q -> String
      severity: Q -> String
      run_ref: Q -> option String
      observed_at: Q -> DateTime
    }
    evidence {
      summary: Q -> option String
      artifact_path: Q -> option String
      artifact_hash: Q -> option String
    }
  }

  actions {
    action record(target_symbol: String, dimension: String, status: String, severity: String, summary: option String, artifact_path: option String, artifact_hash: option String, run_ref: option String) {
      -> ok(signal: Q) {
        Records quality event.
        dimension: snapshot | conformance | contract | unit |
          flaky | selection | formal
        status: pass | fail | warn | unknown | skipped
        severity: gate | warn | info
      }
      -> validationError(message: String) {
        Invalid dimension, status, or severity value.
      }

      fixture record_pass { target_symbol: "clef/concept/Password", dimension: "unit", status: "pass", severity: "gate", summary: "All 42 unit tests passed" }
      fixture record_with_artifact { target_symbol: "clef/concept/Auth", dimension: "formal", status: "pass", severity: "gate", artifact_path: "/reports/auth-proof.json", artifact_hash: "sha256-abc123", run_ref: "run-77" }
      fixture invalid_dimension { target_symbol: "clef/concept/Password", dimension: "magic", status: "pass", severity: "gate" } -> validationError
      fixture invalid_status { target_symbol: "clef/concept/Password", dimension: "unit", status: "excellent", severity: "gate" } -> validationError
      fixture missing_required { target_symbol: "", dimension: "", status: "", severity: "" } -> validationError
    }

    action latest(target_symbol: String, dimension: String) {
      -> ok(signal: Q, status: String, severity: String, summary: option String, observed_at: DateTime) {
        Most recent signal for target+dimension.
      }
      -> notFound(target_symbol: String, dimension: String) {
        No signal recorded.
      }
      -> validationError(message: String) {
        Invalid target_symbol or dimension.
      }

      fixture latest_unit { target_symbol: "clef/concept/Password", dimension: "unit" }
      fixture latest_invalid_dimension { target_symbol: "clef/concept/Password", dimension: "imaginary" } -> validationError
      fixture latest_missing_target { target_symbol: "", dimension: "unit" } -> validationError
    }

    action rollup(target_symbols: list String, dimensions: option list String) {
      -> ok(results: list { target: String, status: String, blocking: Bool }) {
        Worst-of rollup per target.
        blocking=true iff any gate-severity signal has fail or unknown.
        Status ordering: fail > unknown > warn > pass > skipped.
      }
      -> validationError(message: String) {
        Invalid target_symbols or dimensions.
      }

      fixture rollup_single { target_symbols: ["clef/concept/Password"] }
      fixture rollup_multiple { target_symbols: ["clef/concept/Password", "clef/concept/Auth"], dimensions: ["unit", "formal"] }
      fixture rollup_empty_targets { target_symbols: [] } -> validationError
    }

    action explain(target_symbol: String, dimensions: option list String) {
      -> ok(contributors: list { dimension: String, status: String, severity: String, observed_at: DateTime, summary: option String, artifact_path: option String, artifact_hash: option String, run_ref: option String }) {
        Leaf signals for drilldown UI.
      }
      -> validationError(message: String) {
        Invalid target_symbol or dimensions.
      }

      fixture explain_all_dims { target_symbol: "clef/concept/Password" }
      fixture explain_filtered { target_symbol: "clef/concept/Auth", dimensions: ["unit", "conformance"] }
      fixture explain_missing_target { target_symbol: "" } -> validationError
    }
  }

  example "record then latest": {
    after record(target_symbol: "clef/concept/Password", dimension: "formal", status: "pass", severity: "gate", summary: "Proved 3 properties", artifact_path: null, artifact_hash: null, run_ref: "run-1")
      -> ok(signal: q)
    then latest(target_symbol: "clef/concept/Password", dimension: "formal")
      -> ok(signal: q, status: "pass", severity: "gate", summary: "Proved 3 properties", observed_at: t)
  }


  always "signals have required fields": {
    forall q in signals:
    q.target_symbol != none
  }

  never "orphaned entry in signals": {
    exists q in signals:
    q.target_symbol = none
  }

  action record {
    requires: target_symbol != ""
    ensures ok: target_symbol != none
  }

  action latest {
    requires: target_symbol != ""
    ensures ok: target_symbol != none
  }

  action explain {
    requires: target_symbol != ""
    ensures ok: target_symbol != none
  }
}
