@version(2)
concept TestGen [T] {

  purpose {
    Coordinate automated test generation from all six invariant
    construct types. Maps each construct to a generation strategy:
    example → conformance vectors, forall → PBT properties,
    always → stateful sequence tests, never → violation-attempt
    tests, eventually → bounded liveness tests, requires/ensures
    → contract-constrained PBT. Routes to language-specific
    providers via PluginRegistry dispatch.
  }

  state {
    generations: set T

    concept_ref: T -> String
    language: T -> String
    provider_used: T -> String
    generated_files: T -> String
    invariant_version: T -> String
    generated_at: T -> DateTime
    strategies: T -> String

    config {
      num_runs: T -> Int
      fuzz_duration_s: T -> Int
      shrink_enabled: T -> Bool
      stateful_test_depth: T -> Int
    }
  }

  actions {

    action generate(concept_ref: String, language: String, invariant_version: String) {
      -> ok(generation: T, generated_files: String, provider_used: String, strategies: String) {
        Parse concept invariants across all six construct types and
        compile each to the appropriate test strategy. Generates
        conformance tests from example blocks, PBT properties from
        forall blocks, stateful tests from always/never blocks,
        liveness tests from eventually blocks, and contract tests
        from requires/ensures blocks. Routes to language-specific
        provider via PluginRegistry.
      }
      -> invalid(message: String) {
        Concept has no parseable invariants, or no provider is
        registered for the requested language.
      }
    }

    action regenerate(generation: T) {
      -> ok(generation: T, generated_files: String, provider_used: String) {
        Re-generate from the same concept using current invariant
        version. Replaces previous generated files.
      }
      -> notfound(generation: T) {
        No generation record exists with this identifier.
      }
    }

    action list(concept_ref: option String, language: option String) {
      -> ok(generations: list T) {
        Filtered listing of generation records. All params optional.
      }
    }

    action configure(generation: T, num_runs: option Int, fuzz_duration_s: option Int, shrink_enabled: option Bool, stateful_test_depth: option Int) {
      -> ok(generation: T) {
        Update generation configuration for PBT run count, fuzz
        duration, shrink behavior, or stateful test depth.
      }
      -> notfound(generation: T) {
        No generation record exists with this identifier.
      }
    }

    action coverage(concept_ref: String) {
      -> ok(total_invariants: Int, covered: Int, uncovered: Int, coverage_pct: Float, languages: list String, construct_coverage: String) {
        Report how many invariant clauses have generated tests
        across all languages and all construct types for the
        given concept. construct_coverage breaks down coverage
        per invariant kind (example, forall, always, never,
        eventually, requires_ensures).
      }
    }
  }

  example "generate produces strategies for all constructs": {
    after generate(concept_ref: "clef/concept/Password", language: "typescript", invariant_version: "v1")
      -> ok(generation: g, generated_files: files, provider_used: "TestGenTypeScript", strategies: strats)
    then list(concept_ref: "clef/concept/Password", language: "typescript")
      -> ok(generations: gs)
  }

  forall "valid languages accepted": {
    given lang in {"typescript", "rust", "swift", "solidity"}
    after generate(concept_ref: "clef/concept/Test", language: lang, invariant_version: "v1")
      -> ok(generation: _, generated_files: _, provider_used: _, strategies: _)
  }

  never "invalid language accepted": {
    exists g in generations:
      g.language = "python"
  }
}
