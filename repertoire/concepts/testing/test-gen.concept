# @fixtures-added
@version(3)
concept TestGen [T] {

  purpose {
    Coordinate automated test generation from concept specifications.
    Parses a concept spec into a language-neutral test plan covering
    all six invariant construct types, then routes the test plan to
    language-specific providers for rendering into executable test code.

    Test plan structure:
    - structural: per-action program construction, purity, variant
      coverage, read/write sets, interpreted execution, transport effects
    - examples: 1:1 conformance vectors from example invariants
    - properties: PBT descriptors from forall invariants
    - stateInvariants: always/never state predicate checks
    - liveness: bounded sequence tests from eventually invariants
    - contracts: requires/ensures pre/postcondition tests

    Providers render the test plan into language-specific code:
    TypeScript (vitest + fast-check), Rust (proptest + cargo-fuzz),
    Swift (SwiftCheck + XCTest), Solidity (Foundry + Echidna).
  }

  state {
    generations: set T

    concept_ref: T -> String
    language: T -> String
    provider_used: T -> String
    generated_files: T -> String
    invariant_version: T -> String
    generated_at: T -> DateTime
    strategies: T -> String
    test_plan: T -> String

    config {
      num_runs: T -> Int
      fuzz_duration_s: T -> Int
      shrink_enabled: T -> Bool
      stateful_test_depth: T -> Int
    }
  }

  actions {

    action generate(concept_ref: String, language: String, invariant_version: String) {
      -> ok(generation: T, generated_files: String, provider_used: String, strategies: String) {
        Read the concept spec, build a test plan from its actions and
        invariants, store the generation record, and route to the
        language-specific provider for rendering. The test plan covers
        all six invariant construct types mapped to their generation
        strategies.
      }
      -> invalid(message: String) {
        Concept has no parseable invariants, or no provider is
        registered for the requested language.
      }

      fixture generate_typescript { concept_ref: "clef/concept/Password", language: "typescript", invariant_version: "v1" }
      fixture generate_rust { concept_ref: "clef/concept/Auth", language: "rust", invariant_version: "v2" }
      fixture invalid_language { concept_ref: "clef/concept/Password", language: "python", invariant_version: "v1" } -> invalid
      fixture missing_ref { concept_ref: "", language: "typescript", invariant_version: "v1" } -> invalid
    }

    action buildTestPlan(concept_ref: String, concept_data: String) {
      -> ok(test_plan: String, provider: String, language: String) {
        Build a language-neutral test plan from a concept spec passed
        directly as structured data. The test plan is a JSON-serialized
        TestPlan containing structural tests, example conformance
        vectors, forall PBT descriptors, always/never state invariants,
        eventually bounded liveness tests, and requires/ensures
        contract checks. This is the core planning action used by
        scaffold generators and CLI tools.
      }
      -> invalid(message: String) {
        concept_ref or concept_data missing or malformed.
      }

      fixture build_plan_basic { concept_ref: "clef/concept/User", concept_data: "{\"name\":\"User\",\"actions\":[],\"invariants\":[]}" }
      fixture build_plan_missing_ref { concept_ref: "", concept_data: "{}" } -> invalid
    }

    action regenerate(generation: T) {
      -> ok(generation: T, generated_files: String, provider_used: String) {
        Re-generate from the same concept using current invariant
        version. Replaces previous generated files.
      }
      -> notfound(generation: T) {
        No generation record exists with this identifier.
      }

      fixture regenerate_existing { generation: "tg-abc123" }
      fixture regenerate_missing { generation: "tg-nonexistent" }
    }

    action list(concept_ref: option String, language: option String) {
      -> ok(generations: list T) {
        Filtered listing of generation records. All params optional.
      }

      fixture list_all {}
      fixture list_by_concept { concept_ref: "clef/concept/Password" }
    }

    action configure(generation: T, num_runs: option Int, fuzz_duration_s: option Int, shrink_enabled: option Bool, stateful_test_depth: option Int) {
      -> ok(generation: T) {
        Update generation configuration for PBT run count, fuzz
        duration, shrink behavior, or stateful test depth.
      }
      -> notfound(generation: T) {
        No generation record exists with this identifier.
      }

      fixture configure_runs { generation: "tg-abc123", num_runs: 50000 }
      fixture configure_fuzz { generation: "tg-abc123", fuzz_duration_s: 120, shrink_enabled: true }
    }

    action coverage(concept_ref: String) {
      -> ok(total_invariants: Int, covered: Int, uncovered: Int, coverage_pct: Float, languages: list String, construct_coverage: String) {
        Report how many invariant clauses have generated tests
        across all languages and all construct types for the
        given concept. construct_coverage breaks down coverage
        per invariant kind (example, forall, always, never,
        eventually, requires_ensures).
      }

      fixture coverage_password { concept_ref: "clef/concept/Password" }
      fixture coverage_missing { concept_ref: "" }
    }
  }

  example "generate produces strategies for all constructs": {
    after generate(concept_ref: "clef/concept/Password", language: "typescript", invariant_version: "v1")
      -> ok(generation: g, generated_files: files, provider_used: "TestGenTypeScript", strategies: strats)
    then list(concept_ref: "clef/concept/Password", language: "typescript")
      -> ok(generations: gs)
  }

  example "buildTestPlan returns structured plan": {
    after buildTestPlan(concept_ref: "clef/concept/User", concept_data: "{}")
      -> ok(test_plan: plan, provider: "TestGenTypeScript", language: "typescript")
    then plan != ""
  }

  forall "valid languages accepted": {
    given lang in {"typescript", "rust", "swift", "solidity"}
    after generate(concept_ref: "clef/concept/Test", language: lang, invariant_version: "v1")
      -> ok(generation: _, generated_files: _, provider_used: _, strategies: _)
  }

  never "invalid language accepted": {
    exists g in generations:
      g.language = "python"
  }
}
