# @fixtures-added
@version(2)
concept DestinationCatalog [D] {

  purpose {
    Manage named application destinations and their presentation
    metadata so navigation structure can be declared once and
    consumed across shells, routers, and platform adapters.
  }

  state {
    destinations: set D
    name: D -> String
    targetConcept: D -> String
    targetView: D -> String
    href: D -> String
    icon: D -> String
    group: D -> String
  }

  capabilities {
    requires persistent-storage
  }

  actions {
    action register(destination: D, name: String, targetConcept: String,
                    targetView: String, href: String, icon: String, group: String) {
      -> ok(destination: D) { Register a destination and its shell metadata. }
      -> duplicate(message: String) { A destination with this name or href already exists. }

      fixture register_dashboard { destination: "dest-1", name: "dashboard", targetConcept: "AppShell", targetView: "dashboard", href: "/admin", icon: "home", group: "Content" }
      fixture register_articles { destination: "dest-2", name: "articles", targetConcept: "ArticleList", targetView: "list", href: "/articles", icon: "file-text", group: "Content" }
    }

    action resolveByName(name: String) {
      -> ok(destination: D, targetConcept: String, targetView: String,
            href: String, icon: String, group: String) {
        Resolve a destination by its logical name.
      }
      -> notfound(message: String) { No destination exists with this name. }

      fixture resolve_dashboard { name: "dashboard" } after register_dashboard
      fixture resolve_unknown_name { name: "nonexistent" } -> notfound
    }

    action resolveByHref(href: String) {
      -> ok(destination: D, name: String, targetConcept: String, targetView: String,
            href: String, icon: String, group: String) {
        Resolve a destination by href, matching nested paths to their base destination.
      }
      -> notfound(message: String) { No destination matches this href. }

      fixture resolve_admin_href { href: "/admin" } after register_dashboard
      fixture resolve_nested_href { href: "/articles/42" } after register_dashboard
      fixture resolve_unknown_href { href: "/nonexistent" } -> notfound
    }

    action list() {
      -> ok(destinations: list {
        destination: D, name: String, targetConcept: String, targetView: String,
        href: String, icon: String, group: String
      }) {
        Return all registered destinations.
      }

      fixture list_all { } after register_dashboard
    }
  }

  example "register then resolveByName": {
    after register(destination: d, name: "dashboard", targetConcept: "AppShell",
                   targetView: "dashboard", href: "/admin", icon: "home", group: "Content")
      -> ok(destination: d)
    then resolveByName(name: "dashboard")
      -> ok(destination: d, targetConcept: "AppShell", targetView: "dashboard",
            href: "/admin", icon: "home", group: "Content")
  }


  always "destinations have required fields": {
    forall d in destinations:
    d.name != none
  }

  never "orphaned entry in destinations": {
    exists d in destinations:
    d.name = none
  }

  never "top-level view with no destination": {
    // Every seeded View or ViewShell that declares both a title and a
    // description represents a navigable top-level admin page.  If no
    // DestinationCatalog entry binds it to an /admin/<route> href, the
    // URL falls through to DynamicPage which renders a "Page not found"
    // EmptyState — a silent UX regression.  Ensure every such view is
    // reachable: add a DestinationCatalog entry that maps its targetView
    // to the ViewShell or Layout name, and verify the route with
    // curl -sI http://localhost:4006/admin/<route> (expect 307 to login,
    // not 404 or dashboard fallback).
  }

  action register {
    requires: name != ""
    ensures ok: destination != none
  }

  action resolveByName {
    requires: name != ""
    ensures ok: name != none
  }

  action resolveByHref {
    requires: href != ""
    ensures ok: href != none
  }
}
