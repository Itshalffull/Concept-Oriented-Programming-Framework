# Register ManifestAutomationProvider with PluginRegistry as an automation provider

sync RegisterManifestProvider [eager]
when {
  ManifestAutomationProvider/register: []
    => [ provider_name: ?name ]
}
then {
  PluginRegistry/register: [
    type: "automation-provider";
    name: ?name;
    metadata: {
      name: ?name;
      concept: "ManifestAutomationProvider";
      action: "execute";
      category: "automation-provider"
    }
  ]
}
