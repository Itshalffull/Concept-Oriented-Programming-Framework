# @fixtures-added
@version(1)
concept SemanticEmbedding [B] {

  purpose {
    Vector representation of DefinitionUnits for similarity search
    and natural language code search. Cached by content digest so
    embeddings are recomputed only when the underlying code changes.
  }

  state {
    embeddings: set B
    unit: B -> String
    digest: B -> String
    model: B -> String
    vector: B -> String
    dimensions: B -> Int
  }

  capabilities {
    requires persistent-storage
    requires network
  }

  actions {
    action compute(unit: String, model: String) {
      -> ok(embedding: B) {
        Compute a vector embedding for a definition unit using
        the specified model (codeBERT, unixcoder, openai-code,
        voyage-code).
      }
      -> ok(model: String) {
        The requested embedding model is not available.
      }

      fixture compute_codebert { unit: "def-123", model: "codeBERT" }
      fixture compute_unixcoder { unit: "def-456", model: "unixcoder" }
      fixture compute_unknown_model { unit: "def-789", model: "unknown-model" } -> modelUnavailable
    }

    action searchSimilar(queryVector: String, topK: Int, language: String, kind: String) {
      -> ok(results: String) {
        Find definition units most similar to the query vector,
        optionally filtered by language and kind. Results as
        serialized JSON array of { unit, score }.
      }

      fixture search_similar_top5 { queryVector: "[0.1, 0.2, 0.3]", topK: 5, language: "typescript", kind: "function" } after compute_codebert
      fixture search_similar_all { queryVector: "[0.5, -0.3, 0.8]", topK: 0, language: "", kind: "" } after compute_codebert
    }

    action searchNaturalLanguage(query: String, topK: Int) {
      -> ok(results: String) {
        Search for code matching a natural language description.
        Embeds the query and finds nearest definition units.
        Results as serialized JSON array of { unit, score }.
      }

      fixture nl_search_auth { query: "authentication middleware", topK: 3 } after compute_codebert
      fixture nl_search_broad { query: "data validation", topK: 10 } after compute_codebert
    }

    action get(embedding: B) {
      -> ok(embedding: B, unit: String, model: String, dimensions: Int) {
        Retrieve embedding metadata (vector omitted for size).
      }
      -> notfound() {
        Embedding does not exist.
      }

      fixture get_existing { embedding: $compute_codebert.embedding } after compute_codebert
      fixture get_unknown { embedding: "semantic-embedding-nonexistent" } -> notfound
    }
  }

  example "compute-then-get": {

    after compute(unit: "def-123", model: "codeBERT") -> ok(embedding: b)

        then get(embedding: b) -> ok(embedding: b, unit: "def-123", model: "codeBERT", dimensions: _)

  }


  always "valid-unit" {

    forall b in embeddings:

      b.unit != none

  }

  never "orphaned-digest" {

    exists b in embeddings:

      b.digest = none

  }

  action compute {

    requires: unit != ""

    ensures ok: unit != none

  }
}
