@version(2)
concept OpenAIEmbeddingProvider [I] {

  purpose {
    Compute code embeddings via OpenAI's text-embedding API.
    Self-registers with PluginRegistry on initialization so
    SemanticEmbedding can discover and route to this provider.
  }

  state {
    instances: set I
    providerRef: I -> String
    modelName: I -> String
    apiModel: I -> String
    dimensions: I -> Int
    ready: I -> Bool
  }

  capabilities {
    requires persistent-storage
    requires network
  }

  actions {
    action initialize(apiKey: String, apiModel: String, dimensions: Int) {
      -> ok(instance: I) {
        Store provider config and mark ready. The API key is
        validated on first embed call, not during initialization.
        Default apiModel is text-embedding-3-small, default
        dimensions is 1536.
      }
      -> loadError(message: String) {
        Missing or empty API key.
      }
    }

    action embed(text: String) {
      -> ok(vector: String, dimensions: Int) {
        Call the OpenAI embeddings endpoint and return the
        resulting float vector as a JSON array string.
      }
      -> error(message: String) {
        The API call failed due to network error, invalid key,
        rate limiting, or the model returned an unexpected response.
      }
      -> notReady(message: String) {
        Provider has not been initialized yet.
      }
    }
  }

  example "initialize-then-embed": {

    after initialize(apiKey: "sk-test", apiModel: "text-embedding-3-small", dimensions: 1536) -> ok(instance: i)

        then embed(text: "function add(a, b) { return a + b; }") -> ok(vector: v, dimensions: 1536)

  }


  always "valid-providerRef" {

    forall i in instances:

      i.providerRef != none

  }

  never "orphaned-modelName" {

    exists i in instances:

      i.modelName = none

  }

  action initialize {

    requires: apiKey != ""

    ensures ok: apiKey != none

  }
}
