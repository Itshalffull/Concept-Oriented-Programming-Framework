# When a participant forks an idea in a brainstorm board, create a version branch on the idea ContentNode.
# Brainstorm version tree — Section 6.x.

sync BrainstormIdeaForks [eager]
when {
  BrainstormBoard/forkIdea: [ board: ?board; parent_idea_ref: ?parent_ref; fork_idea_ref: ?fork_ref; submitter_ref: ?submitter ]
    => [ board: ?board; fork_idea_ref: ?fork_ref ]
}
then {
  Branch/create: [
    source: ?parent_ref;
    name: concat("fork-", ?fork_ref);
    created_by: ?submitter
  ]
}
