sync RegisterWebhookEndpoint [eager]
  purpose: "Configure an HttpProvider instance for a webhook endpoint when it registers."
when {
  WebhookEndpoint/register: [ name: ?name; url: ?url; headers: ?headers ]
    => ok(endpoint: ?ep)
}
then {
  HttpProvider/configure: [
    name: ?name;
    baseUrl: ?url;
    headers: ?headers;
    timeout: 10000
  ]
  PluginRegistry/register: [
    type: "instance-provider";
    name: ?name;
    metadata: { kind: "webhook"; provider: "webhook"; url: ?url }
  ]
}
