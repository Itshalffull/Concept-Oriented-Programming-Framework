# View resolution flow — when a ViewShell resolves, fan out to fetch child specs.
# Always-on specs (dataSource, presentation) are fetched unconditionally.
# Optional specs are fetched only when their feature is listed in the features field.
# Views without a features field (empty string) default to all features enabled.

sync ViewResolveAlwaysOn [eager]
  purpose: "Fetch the always-on child specs — DataSourceSpec and PresentationSpec — for any resolved ViewShell, since every view must have a data source and a display mode regardless of its features set."
when {
  ViewShell/resolve: [ name: ?name ]
    => [ view: ?view ]
}
where {
  ViewShell: { ?view dataSource: ?dataSource; presentation: ?presentation }
}
then {
  DataSourceSpec/get: [ name: ?dataSource ]
}
then {
  PresentationSpec/get: [ name: ?presentation ]
}

sync ViewResolveFilter [eager]
  purpose: "Fetch the FilterSpec for a resolved ViewShell when the filter feature is enabled. Views that declare features without listing 'filter' skip this fetch entirely."
when {
  ViewShell/resolve: [ name: ?name ]
    => [ view: ?view ]
}
where {
  ViewShell: { ?view filter: ?filter; features: ?features }
  guard(?features = "" or ?features contains "filter")
  guard(?filter != "")
}
then {
  FilterSpec/get: [ name: ?filter ]
}

sync ViewResolveSort [eager]
  purpose: "Fetch the SortSpec for a resolved ViewShell when the sort feature is enabled. Views that declare features without listing 'sort' skip this fetch entirely."
when {
  ViewShell/resolve: [ name: ?name ]
    => [ view: ?view ]
}
where {
  ViewShell: { ?view sort: ?sort; features: ?features }
  guard(?features = "" or ?features contains "sort")
  guard(?sort != "")
}
then {
  SortSpec/get: [ name: ?sort ]
}

