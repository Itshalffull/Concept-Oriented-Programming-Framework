sync ViewResolveInteraction [eager]
  purpose: "Fetch the InteractionSpec for a resolved ViewShell when the interaction feature is enabled. Views that declare features without listing 'interaction' skip this fetch entirely."
when {
  ViewShell/resolve: [ name: ?name ]
    => [ view: ?view ]
