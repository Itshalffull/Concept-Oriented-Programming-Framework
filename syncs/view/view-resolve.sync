sync ViewResolvePagination [eager]
  purpose: "Fetch the PaginationSpec for a resolved ViewShell when the pagination feature is enabled. Only views that explicitly list 'pagination' in their features set trigger this fetch."
when {
  ViewShell/resolve: [ name: ?name ]
    => [ view: ?view ]
}
where {
  ViewShell: { ?view pagination: ?pagination; features: ?features }
  guard(?features contains "pagination")
  guard(?pagination != "")
}
then {
  PaginationSpec/get: [ name: ?pagination ]
}
