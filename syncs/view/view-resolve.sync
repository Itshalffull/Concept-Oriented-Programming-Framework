  purpose: "Fetch the ProjectionSpec for a resolved ViewShell when the projection feature is enabled. Views that declare features without listing 'projection' skip this fetch entirely."
when {
  ViewShell/resolve: [ name: ?name ]
    => [ view: ?view ]
}
where {
  ViewShell: { ?view projection: ?projection; features: ?features }
