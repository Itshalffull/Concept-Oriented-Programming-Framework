# variable-source-providers-boot — Register all 8 built-in VariableSourceProviders
# with PluginRegistry on kernel boot so VariableProgram/resolve can locate them
# via PluginRegistry/get("variable-source", kind).
#
# Each registration is idempotent per PluginRegistry spec — safe to re-fire
# on every boot without creating duplicates.

sync RegisterPageVariableSourceProvider [eager]
  purpose {
    On kernel boot, register the "page" source provider with PluginRegistry so
    VariableProgram can resolve $page expressions against the current page's
    ContentNode record.
  }
when {
  KernelBoot/boot: [ projectRoot: ?projectRoot; manifestPath: ?manifestPath ]
    => ok(kernel: ?kernel; concepts: ?concepts; syncs: ?syncs)
}
then {
  PluginRegistry/register: [
    type: "variable-source";
    name: "page";
    metadata: "{\"impl\":\"PageVariableProvider\",\"prefix\":\"$page\",\"resolvedType\":\"ContentNode\",\"argSpec\":[]}"
  ]
}

sync RegisterUrlVariableSourceProvider [eager]
  purpose {
    On kernel boot, register the "url" source provider with PluginRegistry so
    VariableProgram can resolve $url expressions against URL path and query parameters.
  }
when {
  KernelBoot/boot: [ projectRoot: ?projectRoot; manifestPath: ?manifestPath ]
    => ok(kernel: ?kernel; concepts: ?concepts; syncs: ?syncs)
}
then {
  PluginRegistry/register: [
    type: "variable-source";
    name: "url";
    metadata: "{\"impl\":\"UrlVariableProvider\",\"prefix\":\"$url\",\"resolvedType\":\"string\",\"argSpec\":[{\"name\":\"param\",\"type\":\"string\",\"required\":true}]}"
  ]
}

sync RegisterContentVariableSourceProvider [eager]
  purpose {
    On kernel boot, register the "content" source provider with PluginRegistry so
    VariableProgram can resolve $content expressions against arbitrary ContentNodes by ID.
  }
when {
  KernelBoot/boot: [ projectRoot: ?projectRoot; manifestPath: ?manifestPath ]
    => ok(kernel: ?kernel; concepts: ?concepts; syncs: ?syncs)
}
then {
  PluginRegistry/register: [
    type: "variable-source";
    name: "content";
    metadata: "{\"impl\":\"ContentVariableProvider\",\"prefix\":\"$content\",\"resolvedType\":\"ContentNode\",\"argSpec\":[{\"name\":\"nodeId\",\"type\":\"string\",\"required\":true}]}"
  ]
}

sync RegisterQueryVariableSourceProvider [eager]
  purpose {
    On kernel boot, register the "query" source provider with PluginRegistry so
    VariableProgram can resolve $query expressions against named view query results.
  }
when {
  KernelBoot/boot: [ projectRoot: ?projectRoot; manifestPath: ?manifestPath ]
    => ok(kernel: ?kernel; concepts: ?concepts; syncs: ?syncs)
}
then {
  PluginRegistry/register: [
    type: "variable-source";
    name: "query";
    metadata: "{\"impl\":\"ViewQueryVariableProvider\",\"prefix\":\"$query\",\"resolvedType\":\"any\",\"argSpec\":[{\"name\":\"name\",\"type\":\"string\",\"required\":true}]}"
  ]
}

