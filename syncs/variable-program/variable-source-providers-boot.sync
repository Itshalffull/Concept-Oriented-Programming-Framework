sync RegisterLiteralVariableSourceProvider [eager]
  purpose {
    On kernel boot, register the "literal" source provider with PluginRegistry so
    VariableProgram can resolve single-quoted literal expressions to their constant string value.
  }
when {
  KernelBoot/boot: [ projectRoot: ?projectRoot; manifestPath: ?manifestPath ]
    => ok(kernel: ?kernel; concepts: ?concepts; syncs: ?syncs)
}
then {
  PluginRegistry/register: [
    type: "variable-source";
    name: "literal";
    metadata: "{\"impl\":\"LiteralVariableProvider\",\"prefix\":\"'\",\"resolvedType\":\"string\",\"argSpec\":[{\"name\":\"value\",\"type\":\"string\",\"required\":true}]}"
  ]
}

sync RegisterContextVariableSourceProvider [eager]
  purpose {
    On kernel boot, register the "context" source provider with PluginRegistry so
    VariableProgram can resolve $ctx expressions against ambient context values
    supplied by the hosting surface or process runtime.
  }
when {
  KernelBoot/boot: [ projectRoot: ?projectRoot; manifestPath: ?manifestPath ]
    => ok(kernel: ?kernel; concepts: ?concepts; syncs: ?syncs)
}
then {
  PluginRegistry/register: [
    type: "variable-source";
    name: "context";
    metadata: "{\"impl\":\"ContextVariableProvider\",\"prefix\":\"$ctx\",\"resolvedType\":\"any\",\"argSpec\":[{\"name\":\"key\",\"type\":\"string\",\"required\":true}]}"
  ]
}
