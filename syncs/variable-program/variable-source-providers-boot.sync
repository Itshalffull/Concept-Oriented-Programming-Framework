}
then {
  PluginRegistry/register: [
    type: "variable-source";
    name: "step";
    metadata: "{\"impl\":\"ProcessStepVariableProvider\",\"prefix\":\"$step\",\"resolvedType\":\"any\",\"argSpec\":[{\"name\":\"stepKey\",\"type\":\"string\",\"required\":true}]}"
