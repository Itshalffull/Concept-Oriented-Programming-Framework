# Auto-register the Watchkit render-interpreter provider on first use

sync RegisterWatchkitInterpreterProvider [eager]
  purpose: "Self-register the Watchkit target interpreter in plugin-registry so the RenderInterpreter dispatcher can discover it."
when {
  RenderInterpreterWatchkit/interpret: []
    => []
}
then {
  RenderInterpreterWatchkit/initialize: []
}
