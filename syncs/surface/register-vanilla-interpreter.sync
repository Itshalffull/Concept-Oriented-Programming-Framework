# Auto-register the Vanilla render-interpreter provider on first use

sync RegisterVanillaInterpreterProvider [eager]
  purpose: "Self-register the Vanilla target interpreter in plugin-registry so the RenderInterpreter dispatcher can discover it."
when {
  RenderInterpreterVanilla/interpret: []
    => []
}
then {
  RenderInterpreterVanilla/initialize: []
}
