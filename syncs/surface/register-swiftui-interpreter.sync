# Auto-register the Swiftui render-interpreter provider on first use

sync RegisterSwiftuiInterpreterProvider [eager]
  purpose: "Self-register the Swiftui target interpreter in plugin-registry so the RenderInterpreter dispatcher can discover it."
when {
  RenderInterpreterSwiftui/interpret: []
    => []
}
then {
  RenderInterpreterSwiftui/initialize: []
}
