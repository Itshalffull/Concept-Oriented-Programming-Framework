# Auto-register the Nextjs render-interpreter provider on first use

sync RegisterNextjsInterpreterProvider [eager]
  purpose: "Self-register the Nextjs target interpreter in plugin-registry so the RenderInterpreter dispatcher can discover it."
when {
  RenderInterpreterNextjs/interpret: []
    => []
}
then {
  RenderInterpreterNextjs/initialize: []
}
