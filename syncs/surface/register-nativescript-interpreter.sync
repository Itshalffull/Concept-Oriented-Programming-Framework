# Auto-register the Nativescript render-interpreter provider on first use

sync RegisterNativescriptInterpreterProvider [eager]
  purpose: "Self-register the Nativescript target interpreter in plugin-registry so the RenderInterpreter dispatcher can discover it."
when {
  RenderInterpreterNativescript/interpret: []
    => []
}
then {
  RenderInterpreterNativescript/initialize: []
}
