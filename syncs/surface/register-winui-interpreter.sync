# Auto-register the Winui render-interpreter provider on first use

sync RegisterWinuiInterpreterProvider [eager]
  purpose: "Self-register the Winui target interpreter in plugin-registry so the RenderInterpreter dispatcher can discover it."
when {
  RenderInterpreterWinui/interpret: []
    => []
}
then {
  RenderInterpreterWinui/initialize: []
}
