# @fixtures-added
@version(1)
concept GitLabApiEndpoint [L] {

  purpose {
    Configure and authenticate a GitLab API endpoint for commit
    statuses and pipeline integration. Stores the private token,
    project ID, and configurable API base URL so that higher-level
    concepts reference the endpoint by name.
  }

  state {
    endpoints: set L
    name: L -> String
    token: L -> String
    projectId: L -> String
    baseUrl: L -> String
  }

  capabilities {
    requires persistent-storage
  }

  actions {
    action register(name: String, token: String, projectId: String, baseUrl: String) {
      -> ok(endpoint: L) {
        Create a named GitLab API endpoint with private token,
        CI project ID, and API base URL. Base URL defaults to
        https://gitlab.com/api/v4.
      }
      -> exists(name: String) {
        An endpoint with this name is already registered.
      }

      fixture gitlab_default {
        name: "gitlab-api"
        token: "glpat-abc123def456"
        projectId: "12345"
        baseUrl: "https://gitlab.com/api/v4"
      }

      fixture gitlab_selfhosted {
        name: "gitlab-internal"
        token: "glpat-internal-token"
        projectId: "99"
        baseUrl: "https://git.internal.corp/api/v4"
      }

      fixture missing_name {
        name: ""
        token: "glpat-test"
        projectId: "12345"
        baseUrl: "https://gitlab.com/api/v4"
      } -> error
    }

    action resolve(name: String) {
      -> ok(endpoint: L, baseUrl: String, projectId: String, headers: String) {
        Look up the named endpoint and return its base URL,
        project ID, and pre-built PRIVATE-TOKEN headers.
      }
      -> notFound(name: String) {
        No endpoint is registered with this name.
      }

      fixture resolve_existing {
        name: "gitlab-api"
      }

      fixture resolve_missing {
        name: "nonexistent"
      } -> error
    }

    action list() {
      -> ok(endpoints: String) {
        Return all registered endpoints as a serialized JSON array
        with name, baseUrl, and projectId (tokens omitted).
      }

      fixture valid {}
    }
  }

  example "resolve after register": {
    after register(name: "gitlab-api", token: "glpat-test", projectId: "12345", baseUrl: "https://gitlab.com/api/v4") -> ok(endpoint: l)
    then resolve(name: "gitlab-api") -> ok(endpoint: l, baseUrl: "https://gitlab.com/api/v4", projectId: "12345", headers: _)
  }

  always "endpoints have valid name": {
    forall l in endpoints:
      l.name != none
  }

  never "endpoint without project ID": {
    exists l in endpoints:
      l.projectId = ""
  }

  action register {
    requires: name != ""
    ensures ok: endpoint != none
  }
}
