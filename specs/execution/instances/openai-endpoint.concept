# @fixtures-added
# @fixtures-added
@version(1)
concept OpenAiEndpoint [O] {

  purpose {
    Configure and authenticate a specific OpenAI API endpoint for
    embedding or completion calls. Stores API key, model selection,
    and dimension configuration so that higher-level concepts
    reference endpoints by name rather than embedding credentials.
  }

  state {
    endpoints: set O
    name: O -> String
    apiKey: O -> String
    model: O -> String
    baseUrl: O -> String
    maxTokens: O -> Int
    dimensions: O -> option Int
  }

  capabilities {
    requires persistent-storage
  }

  actions {
    action register(name: String, apiKey: String, model: String, baseUrl: String, dimensions: Int) {
      -> ok(endpoint: O) {
        Create a named OpenAI endpoint configuration with API key,
        model name, base URL, and output dimensions. The endpoint
        becomes addressable by name for HttpProvider instance
        configuration via sync wiring.
      }
      -> ok(name: String) {
        An endpoint with this name is already registered.
      }

      fixture embeddings_endpoint {
        name: "embeddings"
        apiKey: "sk-test-abc123"
        model: "text-embedding-3-small"
        baseUrl: "https://api.openai.com/v1"
        dimensions: 1536
      }

      fixture gpt4_endpoint {
        name: "chat-gpt4"
        apiKey: "sk-prod-xyz789"
        model: "gpt-4"
        baseUrl: "https://api.openai.com/v1"
        dimensions: 0
      }

      fixture missing_name {
        name: ""
        apiKey: "sk-test"
        model: "gpt-4"
        baseUrl: "https://api.openai.com/v1"
        dimensions: 0
      } -> error
    }

    action resolve(name: String) {
      -> ok(endpoint: O, baseUrl: String, model: String, headers: String) {
        Look up the named endpoint and return its base URL, model,
        and pre-built authorization headers ready for HTTP calls.
      }
      -> ok(name: String) {
        No endpoint is registered with this name.
      }

      fixture resolve_existing {
        name: "embeddings"
      }

      fixture resolve_missing {
        name: "nonexistent"
      }
    }

    action list() {
      -> ok(endpoints: String) {
        Return all registered endpoints as a serialized JSON array
        with name, model, and baseUrl (API keys omitted).
      }

      fixture valid {}
    }
  }

  example "resolve after register": {
    after register(name: "embeddings", apiKey: "sk-test", model: "text-embedding-3-small", baseUrl: "https://api.openai.com/v1", dimensions: 1536) -> ok(endpoint: o)
    then resolve(name: "embeddings") -> ok(endpoint: o, baseUrl: "https://api.openai.com/v1", model: "text-embedding-3-small", headers: _)
  }

  example "resolve notFound then register succeeds": {
    after resolve(name: "nonexistent") -> ok(name: "nonexistent")
    then register(name: "test", apiKey: "sk-x", model: "gpt-4", baseUrl: "https://api.openai.com/v1", dimensions: 0) -> ok(endpoint: _)
  }

  always "endpoints have valid name": {
    forall o in endpoints:
      o.name != none
  }

  never "endpoint without model": {
    exists o in endpoints:
      o.model = ""
  }

  action register {
    requires: name != ""
    ensures ok: endpoint != none
  }
}
