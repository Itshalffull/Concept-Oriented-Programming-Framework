# @fixtures-added
@version(1)
concept RateLimiter [R] {

  purpose {
    Enforce request rate limits per endpoint using a token bucket
    algorithm. Prevents exceeding API quotas by tracking available
    tokens, refill rates, and queuing or rejecting excess requests.
  }

  state {
    limiters: set R
    endpoint: R -> String
    tokens: R -> Int
    maxTokens: R -> Int
    refillRate: R -> Int
    refillIntervalMs: R -> Int
    lastRefillAt: R -> String
    waitingCount: R -> Int
  }

  capabilities {
    requires persistent-storage
  }

  actions {
    action configure(endpoint: String, maxTokens: Int, refillRate: Int, refillIntervalMs: Int) {
      -> ok(limiter: R) {
        Create a rate limiter for the named endpoint with a token
        bucket of maxTokens capacity, refilling refillRate tokens
        every refillIntervalMs milliseconds. Starts fully filled.
      }
      -> ok(endpoint: String) {
        A rate limiter is already configured for this endpoint.
      }

      fixture api_limiter { endpoint: "openai-api", maxTokens: 100, refillRate: 10, refillIntervalMs: 1000 }
      fixture duplicate_limiter { endpoint: "openai-api", maxTokens: 50, refillRate: 5, refillIntervalMs: 2000 } -> exists
    }

    action acquire(endpoint: String, tokens: Int) {
      -> ok(limiter: R, remaining: Int) {
        Consume the requested number of tokens. Returns the number
        of tokens remaining after acquisition. Refills tokens based
        on elapsed time since last refill before checking availability.
      }
      -> ok(limiter: R, retryAfterMs: Int) {
        Insufficient tokens available. retryAfterMs indicates the
        minimum wait time before enough tokens will be refilled to
        satisfy this request.
      }
      -> ok(endpoint: String) {
        No rate limiter is configured for this endpoint.
      }

      fixture acquire_tokens { endpoint: "openai-api", tokens: 5 } after api_limiter
      fixture acquire_exhausted { endpoint: "openai-api", tokens: 999 } -> limited
      fixture acquire_no_limiter { endpoint: "unknown-service", tokens: 1 } -> notFound
    }

    action release(endpoint: String, tokens: Int) {
      -> ok(limiter: R, remaining: Int) {
        Return tokens to the bucket, up to maxTokens. Use when a
        request completes faster than expected or is cancelled,
        freeing capacity for other requests.
      }
      -> ok(endpoint: String) {
        No rate limiter is configured for this endpoint.
      }

      fixture release_tokens { endpoint: "openai-api", tokens: 3 } after acquire_tokens
      fixture release_no_limiter { endpoint: "unknown-service", tokens: 1 } -> notFound
    }

    action get(endpoint: String) {
      -> ok(limiter: R, tokens: Int, maxTokens: Int, waitingCount: Int) {
        Return the current state of the rate limiter for
        diagnostics, including available tokens and queue depth.
      }
      -> ok(endpoint: String) {
        No rate limiter is configured for this endpoint.
      }

      fixture get_status { endpoint: "openai-api" } after api_limiter
      fixture get_no_limiter { endpoint: "unknown-service" } -> notFound
    }

    action reset(endpoint: String) {
      -> ok(limiter: R) {
        Refill the bucket to maxTokens and clear the waiting count.
        Use for manual recovery or testing.
      }
      -> ok(endpoint: String) {
        No rate limiter is configured for this endpoint.
      }

      fixture reset_limiter { endpoint: "openai-api" } after api_limiter
      fixture reset_no_limiter { endpoint: "unknown-service" } -> notFound
    }
  }

  example "acquire succeeds after configure": {
    after configure(endpoint: "openai-api", maxTokens: 100, refillRate: 10, refillIntervalMs: 1000) -> ok(limiter: r)
    then acquire(endpoint: "openai-api", tokens: 1) -> ok(limiter: r, remaining: 99)
  }

  example "acquire limited when tokens exhausted": {
    after configure(endpoint: "test-api", maxTokens: 2, refillRate: 1, refillIntervalMs: 60000) -> ok(limiter: r)
    and  acquire(endpoint: "test-api", tokens: 2) -> ok(limiter: r, remaining: 0)
    then acquire(endpoint: "test-api", tokens: 1) -> ok(limiter: r, retryAfterMs: _)
  }

  always "limiters have valid endpoint": {
    forall r in limiters:
      r.endpoint != none
  }

  never "negative token count": {
    exists r in limiters:
      r.maxTokens = -1
  }

  action configure {
    requires: endpoint != ""
    ensures ok: maxTokens != none
  }

  action acquire {
    requires: endpoint != ""
    ensures ok: remaining != none
  }
}
