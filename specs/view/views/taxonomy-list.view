view "taxonomy-list" {
  shell: "taxonomy-list"

  features {
    filter
    sort
    projection
  }

  purpose {
    Browse hierarchical classification using Vocabularies and Terms.
  }

  invariants {
    always "purity is read-only": { purity = "read-only" }
    always "no invoke instructions": { invokeCount = 0 }
  }
}
