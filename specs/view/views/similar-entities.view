view "similar-entities" {
  shell: "similar-entities"

  features {
    sort
    projection
  }

  purpose {
    Semantically similar entities based on content similarity
    scoring. Sorted by similarity rank. Read-only.
  }

  invariants {
    always "purity is read-only": {
      purity = "read-only"
    }

    always "no invoke instructions": {
      invokeCount = 0
    }
  }
}
