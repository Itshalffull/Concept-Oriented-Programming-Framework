view "process-health" {
  shell: "process-health"

  features {
    projection
  }

  fixture default {
    dataSource: {
      kind: "concept-action",
      config: "{\"concept\":\"ProcessRun\",\"action\":\"stats\"}"
    }
    projection: {
      fields: "[]"
    }
    presentation: {
      displayType: "stat-cards",
      hints: "{}"
    }
  }

  purpose {
    Live health snapshot of all process runs — active, suspended,
    failed, and completed counts.
  }

  invariants {
    always "purity is read-only": {
      purity = "read-only"
    }

    always "no invoke instructions": {
      invokeCount = 0
    }
  }
}
