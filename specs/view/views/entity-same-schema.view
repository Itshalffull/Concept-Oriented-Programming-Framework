view "entity-same-schema" {
  shell: "entity-same-schema"

  features {
    filter
    sort
    projection
    pagination
  }

  purpose {
    Other entities sharing the same primary schema as the current
    entity. Paginated, filterable table. Read-only.
  }

  invariants {
    always "purity is read-only": {
      purity = "read-only"
    }

    always "has pagination": {
      "pagination" in enabledFeatures
    }

    always "no invoke instructions": {
      invokeCount = 0
    }
  }
}
