view "agent-library" {
  shell: "agent-library"

  features {
    filter
    sort
    projection
    interaction
  }

  purpose {
    Browse and manage agent persona cards with filtering by
    capability and status. Read-write — supports creating and
    editing agent personas inline.
  }

  invariants {
    always "purity is read-write": {
      purity = "read-write"
    }

    always "invokes only ContentNode actions": {
      forall ia in invokedActions:
      ia startsWith "ContentNode/"
    }

    always "all invoke variants covered": {
      uncoveredVariants = []
    }

    always "filter fields exist in source": {
      forall f in filterFields:
      f in sourceFields
    }
  }
}
