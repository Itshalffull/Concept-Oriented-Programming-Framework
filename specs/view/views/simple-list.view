view "simple-list" {
  shell: "simple-list"

  features {
    sort
  }

  fixture default {
    dataSource: {
      kind: "concept-action",
      config: "{\"concept\":\"ContentNode\",\"action\":\"list\"}"
    }
    sort: {
      keys: "[]"
    }
    presentation: {
      displayType: "table",
      hints: "{}"
    }
  }

  purpose {
    Minimal data listing with no filtering or actions.
  }

  invariants {
    always "read-only": {
      purity = "read-only"
    }
  }
}
