view "entity-properties" {
  shell: "entity-properties"

  features {
    projection
  }

  purpose {
    Structured fields zone of the entity detail page showing
    typed schema properties. Read-only.
  }

  invariants {
    always "purity is read-only": {
      purity = "read-only"
    }

    always "no invoke instructions": {
      invokeCount = 0
    }
  }
}
