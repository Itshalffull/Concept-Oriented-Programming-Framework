view "backlinks" {
  shell: "backlinks"

  features {
    sort
    projection
  }

  purpose {
    Entities that reference the current entity via formal links.
    Sorted by relevance or recency. Read-only.
  }

  invariants {
    always "purity is read-only": {
      purity = "read-only"
    }

    always "no invoke instructions": {
      invokeCount = 0
    }
  }
}
