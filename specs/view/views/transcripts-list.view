view "transcripts-list" {
  shell: "transcripts-list"

  features {
    filter
    sort
    projection
    pagination
  }

  purpose {
    Browse audio and video transcripts with time-synchronized text.
    Table layout with status badges and language indicators.
    Read-only, paginated.
  }

  invariants {
    always "purity is read-only": {
      purity = "read-only"
    }

    always "no invoke instructions": {
      invokeCount = 0
    }

    always "has pagination": {
      enabledFeatures contains "pagination"
    }
  }
}
