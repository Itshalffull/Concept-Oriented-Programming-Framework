view "unlinked-references" {
  shell: "unlinked-references"

  features {
    sort
    projection
  }

  purpose {
    Entities that mention the current entity but lack a formal
    link. Candidates for link creation. Read-only.
  }

  invariants {
    always "purity is read-only": {
      purity = "read-only"
    }

    always "no invoke instructions": {
      invokeCount = 0
    }
  }
}
