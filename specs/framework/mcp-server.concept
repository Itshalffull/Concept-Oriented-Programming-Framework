# @fixtures-added
@version(2)
concept McpServer [S] {

  purpose {
    Serve the MCP protocol over stdio, auto-discovering and
    registering all tools generated by any Bind MCP target,
    and routing tool calls to concept handlers. Supports lazy
    loading mode where only core tools are sent upfront with
    full schemas, while remaining tools are discoverable via
    search_tools and describe_tools meta-tools.
  }

  state {
    tools: set S
    toolName: S -> String
    toolConcept: S -> String
    toolAction: S -> String
    toolDescription: S -> String
    toolSchema: S -> String
    alwaysLoaded: S -> Bool
    status: option String
    transport: option String
    manifestPath: option String
    lazyLoading: option Bool
  }

  actions {
    action start(manifestPath: String, transport: String) {
      -> ok(status: String, toolCount: Int, alwaysLoadedCount: Int, deferredCount: Int) {
        Read the Bind interface manifest at the given path, find
        its MCP target output directory, dynamically import all
        generated .tools.ts files, load tool catalogs for brief
        descriptions, register all tools in the ToolDiscovery
        catalog, and boot the MCP server. In lazy loading mode,
        only always-loaded tools are sent with full schemas.
      }
      -> error(message: String) {
        The manifest was not found, has no MCP target, or the
        server failed to bind to the transport.
      }

      fixture valid_start { manifestPath: "examples/devtools/devtools.interface.yaml", transport: "stdio" }
      fixture sse_start { manifestPath: "examples/devtools/devtools.interface.yaml", transport: "sse" }
      fixture invalid_transport { manifestPath: "examples/devtools/devtools.interface.yaml", transport: "websocket" } -> error
    }

    action registerTool(name: String, concept: String, action: String, description: String, schema: String) {
      -> ok(tool: S) {
        Register a tool that routes MCP tool calls to the given
        concept action. The schema is a JSON Schema for input
        validation.
      }
      -> duplicate(name: String) {
        A tool with this name is already registered.
      }

      fixture valid_register_tool { name: "user_create", concept: "User", action: "create", description: "Create a new user account", schema: "{\"type\":\"object\",\"properties\":{\"email\":{\"type\":\"string\"}},\"required\":[\"email\"]}" }
      fixture duplicate_tool { name: "user_create", concept: "User", action: "create", description: "duplicate entry", schema: "{}" } -> duplicate
    }

    action handleCall(toolName: String, arguments: String) {
      -> ok(result: String) {
        Route the tool call to its registered concept handler,
        execute the action, and return the result as JSON. Both
        always-loaded and deferred tools are callable — the LLM
        just needs to discover deferred tools first via
        search_tools and load their schemas via describe_tools.
      }
      -> notfound(toolName: String) {
        No tool is registered with this name.
      }
      -> error(message: String) {
        The concept handler returned an error variant or threw.
      }

      fixture valid_call { toolName: "user_create", arguments: "{\"email\":\"alice@example.com\"}" }
      fixture unknown_tool { toolName: "nonexistent_tool", arguments: "{}" } -> notfound
    }

    action stop() {
      -> ok(status: String) {
        Shut down the MCP server and release the transport.
      }
      -> error(message: String) {
        The server was not running or failed to shut down cleanly.
      }

      fixture valid_stop {}
    }

    action listTools() {
      -> ok(tools: String) {
        Return all registered tools as a JSON array with name,
        concept, action, and description for each.
      }

      fixture valid_list_tools {}
    }
  }

  example "register tool then list includes it": {
    after registerTool(name: "score_query", concept: "ScoreQuery", action: "query", description: "Run a GraphQL query", schema: "{}") -> ok(tool: t)
    then listTools() -> ok(tools: ts)
  }

  example "duplicate registration rejected": {
    after registerTool(name: "score_query", concept: "ScoreQuery", action: "query", description: "Run a GraphQL query", schema: "{}") -> ok(tool: t)
    and  registerTool(name: "score_query", concept: "ScoreQuery", action: "query", description: "duplicate", schema: "{}") -> duplicate(name: n)
    then listTools() -> ok(tools: ts)
  }

  example "handle call for unregistered tool": {
    after handleCall(toolName: "nonexistent", arguments: "{}") -> notfound(toolName: "nonexistent")
  }

  always "registered tools have schemas": {
    forall s in tools:
    s.toolSchema != ""
  }

  never "tool registered without a concept mapping": {
    forall s in tools:
    s.toolConcept = ""
  }

  action registerTool {
    requires: name != "" and concept != "" and action != ""
    ensures ok: tool in tools
  }

  action start {
    requires: manifestPath != ""
    ensures ok: toolCount >= 0
  }
}
