# @fixtures-added
concept StorageProvider [S] {

  purpose {
    Provision and manage persistent storage backends for deployed concepts,
    so the deployment pipeline can create storage resources, retrieve
    connection credentials, and tear them down independent of provider.
  }

  state {
    stores: set S
    storeName: S -> String
    storageType: S -> String
    conceptName: S -> String
    status: S -> String
    credentials: S -> String
    config: S -> String
    provisionedAt: S -> DateTime
  }

  actions {
    action provision(store: S, storeName: String, storageType: String, conceptName: String, config: String) {
      -> ok(store: S, credentials: String) {
        Create a new storage backend of the given type, returning
        connection credentials the concept needs to connect.
      }
      -> alreadyProvisioned(store: S, credentials: String) {
        A store with this name already exists; return its existing credentials.
      }
      -> provisionFailed(store: S, reason: String) {
        The storage backend could not be created, e.g. quota exceeded,
        invalid configuration, or provider API error.
      }

      fixture valid_provision { store: "store-001", storeName: "session-kv", storageType: "vercel-kv", conceptName: "Session", config: "{}" }
      fixture missing_name { store: "store-002", storeName: "", storageType: "vercel-kv", conceptName: "Session", config: "{}" } -> provisionFailed
      fixture missing_type { store: "store-003", storeName: "session-kv", storageType: "", conceptName: "Session", config: "{}" } -> provisionFailed
    }

    action configure(store: S, settings: String) {
      -> ok(store: S) {
        Apply additional configuration to an existing store, such as
        TTL policies, key prefixes, or access restrictions.
      }
      -> notfound(store: S) {
        No provisioned store exists with this identifier.
      }

      fixture valid_configure { store: "session-kv", settings: "{\"ttl\": 3600}" } after valid_provision
      fixture not_found_configure { store: "nonexistent-store", settings: "{}" } after valid_provision -> notfound
    }

    action getCredentials(store: S) {
      -> ok(store: S, credentials: String) {
        Return the current connection credentials for a provisioned store.
      }
      -> notfound(store: S) {
        No provisioned store exists with this identifier.
      }

      fixture valid_get_credentials { store: "session-kv" } after valid_provision
      fixture not_found_credentials { store: "nonexistent-store" } -> notfound
    }

    action destroy(store: S) {
      -> ok(store: S) {
        Tear down the storage backend and release all associated resources.
      }
      -> notfound(store: S) {
        No provisioned store exists with this identifier.
      }

      fixture valid_destroy { store: "session-kv" } after valid_provision
      fixture not_found_destroy { store: "nonexistent-store" } -> notfound
    }
  }

  example "provision then get credentials": {
    after provision(store: s1, storeName: "test-kv", storageType: "vercel-kv", conceptName: "Session", config: "{}") -> ok(store: s1, credentials: creds)
    then getCredentials(store: s1) -> ok(store: s1, credentials: creds)
  }

  example "provision then destroy then credentials not found": {
    after provision(store: s1, storeName: "test-kv", storageType: "vercel-kv", conceptName: "Session", config: "{}") -> ok(store: s1, credentials: creds)
    then destroy(store: s1) -> ok(store: s1)
    and getCredentials(store: s1) -> notfound(store: s1)
  }

  always "provisioned stores have credentials": {
    forall s in stores:
    s.status = "provisioned" and s.credentials != ""
  }

  never "store without a name": {
    forall s in stores:
    s.storeName = ""
  }

  action provision {
    requires: storeName != "" and storageType != ""
    ensures ok: credentials != ""
  }

  action destroy {
    requires: store in stores
    ensures ok: store not in stores
  }
}
