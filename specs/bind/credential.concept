@version(1)
@category("bind")
@visibility("public")
concept Credential [C] {

  purpose {
    Manage named client-side connection profiles, each binding a kernel
    endpoint to stored authentication credentials. Supports multiple
    profiles for different environments and multiple auth methods, enabling
    users and agents to switch between connections without re-entering
    credentials each time.
  }

  state {
    profiles: set C
    identity {
      name: C -> String
      endpoint: C -> String
      method: C -> String
    }
    credential {
      token: C -> option String
      expiresAt: C -> option String
    }
    status: C -> "valid" | "expired" | "unset"
  }

  actions {
    action create(profile: C, name: String, endpoint: String, method: String) {
      -> ok(profile: C) {
        Add the profile to the profiles set with the given name, endpoint,
        and method. Set status to "unset" with no token stored.
      }
      -> duplicate(message: String) {
        A profile with that name already exists; no new profile is created.
      }

      fixture create_ok { profile: "c-staging", name: "staging", endpoint: "wss://staging.example.com", method: "oauth" }
      fixture create_default { profile: "c-default", name: "default", endpoint: "wss://localhost:8080", method: "apikey" }
      fixture create_duplicate { profile: "c-dup", name: "staging", endpoint: "wss://other.example.com", method: "token" } after create_ok -> duplicate
      fixture create_empty_name { profile: "c-bad", name: "", endpoint: "wss://example.com", method: "apikey" } -> duplicate
    }

    action store(profile: C, token: String, expiresAt: option String) {
      -> ok(profile: C) {
        Save the token and optional expiration timestamp for the profile.
        Set status to "valid".
      }
      -> notfound(message: String) {
        No profile exists with that identifier; the credential cannot be stored.
      }

      fixture store_ok { profile: $create_ok.profile, token: "tok_abc123", expiresAt: "2099-12-31T00:00:00Z" } after create_ok
      fixture store_no_expiry { profile: $create_default.profile, token: "apikey_xyz789", expiresAt: none } after create_default
      fixture store_notfound { profile: "c-missing", token: "tok_abc", expiresAt: none } -> notfound
    }

    action load(profile: C) {
      -> ok(profile: C, token: String, endpoint: String) {
        Return the stored token and endpoint for the profile, ready to
        pass to a connection action.
      }
      -> notfound(message: String) {
        No profile exists with that identifier.
      }
      -> expired(message: String) {
        The profile exists and has a token, but the token's expiresAt
        timestamp is in the past.
      }

      fixture load_ok { profile: $store_ok.profile } after store_ok
      fixture load_no_expiry { profile: $store_no_expiry.profile } after store_no_expiry
      fixture load_unset { profile: $create_ok.profile } after create_ok -> expired
      fixture load_notfound { profile: "c-missing" } -> notfound
    }

    action refresh(profile: C) {
      -> ok(profile: C, token: String) {
        Replace the stored token and expiresAt with fresh values from the
        auth provider. Set status to "valid".
      }
      -> notfound(message: String) {
        No profile exists with that identifier.
      }
      -> error(message: String) {
        The refresh attempt failed because the refresh token was revoked,
        the auth provider is unreachable, or the method does not support
        token refresh.
      }

      fixture refresh_ok { profile: $store_ok.profile } after store_ok
      fixture refresh_notfound { profile: "c-missing" } -> notfound
      fixture refresh_error { profile: $create_ok.profile } after create_ok -> error
    }

    action remove(profile: C) {
      -> ok(profile: C) {
        Delete the profile and all associated credentials from the store.
      }
      -> notfound(message: String) {
        No profile exists with that identifier; nothing is deleted.
      }

      fixture remove_ok { profile: $create_ok.profile } after create_ok
      fixture remove_notfound { profile: "c-missing" } -> notfound
    }

    action list() {
      -> ok(profiles: String) {
        Return a summary of all profiles — name, endpoint, method, and
        status — without exposing any stored token values.
      }

      fixture list_empty {}
      fixture list_with_profiles {} after create_ok, create_default
    }
  }

  example "create then store then load": {
    after create(profile: c, name: "prod", endpoint: "wss://prod.example.com", method: "apikey") -> ok(profile: c)
    and   store(profile: c, token: "tok_prod_123", expiresAt: none) -> ok(profile: c)
    then  load(profile: c) -> ok(profile: c, token: "tok_prod_123", endpoint: "wss://prod.example.com")
  }

  example "create without store returns expired on load": {
    after create(profile: c, name: "bare", endpoint: "wss://bare.example.com", method: "token") -> ok(profile: c)
    then  load(profile: c) -> expired(message: _)
  }

  example "duplicate name rejected": {
    after create(profile: c1, name: "dev", endpoint: "wss://dev.example.com", method: "apikey") -> ok(profile: c1)
    then  create(profile: c2, name: "dev", endpoint: "wss://other.example.com", method: "oauth") -> duplicate(message: _)
  }

  example "remove then load returns notfound": {
    after create(profile: c, name: "tmp", endpoint: "wss://tmp.example.com", method: "token") -> ok(profile: c)
    and   remove(profile: c) -> ok(profile: c)
    then  load(profile: c) -> notfound(message: _)
  }

  example "list never exposes tokens": {
    after create(profile: c, name: "safe", endpoint: "wss://safe.example.com", method: "apikey") -> ok(profile: c)
    and   store(profile: c, token: "secret_token_value", expiresAt: none) -> ok(profile: c)
    then  list() -> ok(profiles: _)
  }

  always "profiles have identity fields": {
    forall c in profiles:
    c.name != none
  }

  never "unset profile has token": {
    exists c in profiles:
    c.status = "unset" and c.token != none
  }

  action create {
    requires: name != ""
    requires: endpoint != ""
    requires: method != ""
    ensures ok: profile in profiles
    ensures duplicate: message != ""
  }

  action store {
    requires: token != ""
    ensures ok: profile in profiles
    ensures notfound: message != ""
  }

  action load {
    ensures ok: token != ""
    ensures ok: endpoint != ""
    ensures notfound: message != ""
    ensures expired: message != ""
  }

  action refresh {
    ensures ok: token != ""
    ensures notfound: message != ""
    ensures error: message != ""
  }

  action remove {
    ensures ok: profile != none
    ensures notfound: message != ""
  }
}
